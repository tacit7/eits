{
  "SessionStart": [
    {
      "hooks": [
        {
          "command": "bash /Users/urielmaldonado/projects/eits/web/priv/scripts/eits-codex-notify.sh",
          "timeout": 15,
          "statusMessage": "Updating EITS session status..."
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "command": "bash /Users/urielmaldonado/projects/eits/web/priv/scripts/eits-codex-notify.sh",
          "timeout": 10,
          "statusMessage": "Updating EITS session status..."
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "command": "bash /Users/urielmaldonado/projects/eits/web/priv/scripts/eits-codex-notify.sh",
          "timeout": 15,
          "statusMessage": "Checking EITS tool guard..."
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "command": "bash /Users/urielmaldonado/projects/eits/web/priv/scripts/eits-codex-notify.sh",
          "timeout": 15,
          "statusMessage": "Updating EITS tool state..."
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "hooks": [
        {
          "command": "bash /Users/urielmaldonado/projects/eits/web/priv/scripts/eits-codex-notify.sh",
          "timeout": 10,
          "statusMessage": "Marking EITS session compacting..."
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "command": "bash /Users/urielmaldonado/projects/eits/web/priv/scripts/eits-codex-notify.sh",
          "timeout": 30,
          "statusMessage": "Updating EITS session status..."
        }
      ]
    }
  ]
}
