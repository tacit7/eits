# Copy to .env and fill in values
# Phoenix loads this automatically via dotenvy at startup

# REST API bearer token — generate with: mix eits.gen.api_key
EITS_API_KEY=

# Gitea webhook HMAC secret
GITEA_WEBHOOK_SECRET=

# VAPID keys for Web Push notifications — required in prod, optional in dev
# Generate with:
#   mix run -e '{pub, priv} = :crypto.generate_key(:ecdh, :prime256v1); IO.puts("VAPID_PUBLIC_KEY=#{Base.url_encode64(pub, padding: false)}"); IO.puts("VAPID_PRIVATE_KEY=#{Base.url_encode64(priv, padding: false)}")'
# Rotating keys invalidates all existing push subscriptions (clients must re-subscribe)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# WebAuthn origin override (useful for ngrok tunnels)
# WEBAUTHN_ORIGIN=https://your-ngrok-url.ngrok.io
# WEBAUTHN_RP_ID=your-ngrok-url.ngrok.io

# NVM path (defaults to ~/.nvm if unset)
# NVM_DIR=~/.nvm

# Start HTTP server in release mode
# PHX_SERVER=true
