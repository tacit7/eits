# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
eye_in_the_sky_web-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# Vite prod build output (fingerprinted files and compressed artifacts)
/priv/static/.vite/
/priv/static/**/*.gz
/priv/static/manifest-*.json
/priv/static/sw-*.js
/priv/static/robots-*.txt
/priv/static/favicon-*.ico

# Superpowers
/.superpowers/

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/
/node_modules/

# Database files
*.db
*.db-*

# OS files
.DS_Store

# Logs
/logs/

# Test screenshots
*.png

# Test scripts
test_*.js

# Diagnostic files
*_diagnostic.json


# Ignore automatically generated Svelte files by the ~V sigil
/assets/svelte/_build/

# Ignore ssr build for svelte.
/priv/svelte/

.playwright/
.playwright-mcp/

# Git worktrees managed by Claude Code
.claude/worktrees/
/.claude/
/priv/static/uploads/
priv/cert/

# Local env vars (use .env.example as template)
.env
deps
assets/node_modules

# PR review scratch files
pr-*.md

# Generated mockup previews
/priv/static/mockups/
/priv/static/mockups-*.html
