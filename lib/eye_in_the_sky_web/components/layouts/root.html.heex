<!DOCTYPE html>
<html
  lang="en"
  data-theme={
    case EyeInTheSky.Settings.get("theme") do
      nil -> "dark"
      "" -> "dark"
      theme -> theme
    end
  }
  data-cm-tab-size={EyeInTheSky.Settings.get("cm_tab_size") || "2"}
  data-cm-font-size={EyeInTheSky.Settings.get("cm_font_size") || "14"}
  data-cm-vim={
    case EyeInTheSky.Settings.get("cm_vim") do
      "true" -> "true"
      _ -> "false"
    end
  }
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1e1c1a" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="EITS" />
    <link rel="apple-touch-icon" href="/images/logo.svg" />
    <.live_title default="EyeInTheSky" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=DM+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=DM+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <PhoenixVite.Components.assets
      names={["js/app.js"]}
      manifest={{:eye_in_the_sky, "priv/static/.vite/manifest.json"}}
      dev_server={PhoenixVite.Components.has_vite_watcher?(EyeInTheSkyWeb.Endpoint)}
      to_url={
        if PhoenixVite.Components.has_vite_watcher?(EyeInTheSkyWeb.Endpoint),
          do: fn p ->
            Application.get_env(:eye_in_the_sky, :vite_host, "http://localhost:5173") <> p
          end,
          else: fn "/" <> _ = p -> p end
      }
    />
    <script nonce={assigns.csp_nonce}>
      // Override server-rendered data-theme if localStorage has a saved value
      const saved = localStorage.getItem("theme");
      if (saved) document.documentElement.setAttribute("data-theme", saved);
      // Override server-rendered data-cm-tab-size if localStorage has a saved value
      const savedTabSize = localStorage.getItem("cm_tab_size");
      if (savedTabSize) document.documentElement.setAttribute("data-cm-tab-size", savedTabSize);
      // Override server-rendered data-cm-font-size if localStorage has a saved value
      const savedFontSize = localStorage.getItem("cm_font_size");
      if (savedFontSize) document.documentElement.setAttribute("data-cm-font-size", savedFontSize);
      // Restore vim mode from localStorage
      const savedVim = localStorage.getItem("cm_vim");
      if (savedVim !== null) document.documentElement.setAttribute("data-cm-vim", savedVim);
      // Mark <html> as running inside the Tauri shell so CSS and templates can
      // hide "Open in Desktop App" entry points (they're useless in-app).
      if (/Tauri/i.test(navigator.userAgent) || window.__TAURI_INTERNALS__) {
        document.documentElement.setAttribute("data-env", "tauri");
      }
    </script>
  </head>
  <body class="bg-base-100 min-h-[100dvh] overflow-hidden">
    {@inner_content}
  </body>
</html>
