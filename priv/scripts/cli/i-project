#!/usr/bin/env bash
# i-project - Project management
# Usage:
#   i-project add --name STR [--slug STR] [--path STR] [--remote_url STR] [--branch STR]
#   i-project list
#   i-project get PROJECT_ID

set -euo pipefail

BASE=${EITS_API_URL:-http://localhost:5001/api/v1}

EITS_PG_DB="${EITS_PG_DB:-eits_dev}"
EITS_PG_USER="${EITS_PG_USER:-postgres}"
EITS_PG_HOST="${EITS_PG_HOST:-localhost}"
export PGPASSWORD="${EITS_PG_PASSWORD:-postgres}"
_pgq() { psql -U "$EITS_PG_USER" -h "$EITS_PG_HOST" -d "$EITS_PG_DB" -t -A -c "$1" 2>/dev/null; }

_curl() { curl -sk "$@"; }
_ok() { local r="$1"; echo "$r" | jq .; if echo "$r" | jq -e '.error' &>/dev/null; then exit 1; fi; }

cmd="${1:-list}"
shift || true

case "$cmd" in
  add)
    body="{}"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --name)       body=$(echo "$body" | jq --arg v "$2" '. + {name: $v}'); shift 2 ;;
        --slug)       body=$(echo "$body" | jq --arg v "$2" '. + {slug: $v}'); shift 2 ;;
        --path)       body=$(echo "$body" | jq --arg v "$2" '. + {path: $v}'); shift 2 ;;
        --remote_url) body=$(echo "$body" | jq --arg v "$2" '. + {remote_url: $v}'); shift 2 ;;
        --git_remote) body=$(echo "$body" | jq --arg v "$2" '. + {git_remote: $v}'); shift 2 ;;
        --repo_url)   body=$(echo "$body" | jq --arg v "$2" '. + {repo_url: $v}'); shift 2 ;;
        --branch)     body=$(echo "$body" | jq --arg v "$2" '. + {branch: $v}'); shift 2 ;;
        *) shift ;;
      esac
    done
    _ok "$(_curl -X POST "$BASE/projects" -H 'Content-Type: application/json' -d "$body")"
    ;;

  list)
    _pgq "SELECT row_to_json(r) FROM (SELECT id, name, path, active FROM projects ORDER BY id) r" \
      | jq -s '{success:true, projects:.}'
    ;;

  get)
    id="${1:?project id required}"
    _pgq "SELECT row_to_json(r) FROM (SELECT id, name, path, slug, active FROM projects WHERE id = $id LIMIT 1) r" \
      | jq '{success:true, project:.}'
    ;;

  *)
    echo "Usage: i-project <add|list|get> [args...]" >&2
    exit 1
    ;;
esac
