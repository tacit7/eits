#!/usr/bin/env bash
# eits - CLI for the Eye in the Sky REST API
# Base URL defaults to http://localhost:5001/api/v1
# Override with EITS_URL env var
#
# Session env vars (injected by EITS hooks):
#   EITS_SESSION_UUID  - current session UUID
#   EITS_AGENT_UUID    - current agent UUID (default for --agent)
#   EITS_PROJECT_ID    - current project ID  (default for --project)

set -euo pipefail

BASE_URL="${EITS_URL:-http://localhost:5001/api/v1}"
AUTH_ARGS=()
[[ -n "${EITS_API_KEY:-}" ]] && AUTH_ARGS=(-H "Authorization: Bearer ${EITS_API_KEY}")

# Check deps
command -v curl &>/dev/null || { echo "error: curl is required" >&2; exit 1; }
command -v jq   &>/dev/null || { echo "error: jq is required" >&2; exit 1; }

# ── helpers ──────────────────────────────────────────────────────────────────

_curl() {
  local _body _status
  _body=$(curl -sk --write-out '\n%{http_code}' "${AUTH_ARGS[@]}" "$@")
  _status="${_body##*$'\n'}"
  _body="${_body%$'\n'*}"
  if [[ "$_status" -ge 400 ]]; then
    printf 'HTTP %s: %s\n' "$_status" "$_body" >&2
    return 1
  fi
  printf '%s\n' "$_body"
}

_get()    { _curl "$BASE_URL$1" | jq .; }
_post()   { _curl -X POST  -H "Content-Type: application/json" -d "$2" "$BASE_URL$1" | jq .; }
_patch()  { _curl -X PATCH -H "Content-Type: application/json" -d "$2" "$BASE_URL$1" | jq .; }
_delete() { _curl -X DELETE "$BASE_URL$1" | jq .; }

die()  { echo "error: $*" >&2; exit 1; }
need() { [[ -n "${!1:-}" ]] || die "$1 is required"; }

# Build a compact JSON object from key=value pairs, skipping empty values.
# Usage: json key1 val1 key2 val2 ...
json() {
  local args=("$@")
  local obj="{}"
  local i=0
  while [[ $i -lt ${#args[@]} ]]; do
    local k="${args[$i]}"
    local v="${args[$(($i+1))]}"
    i=$(($i+2))
    [[ -z "$v" ]] && continue
    if [[ "$k" == *_id && "$v" =~ ^[0-9]+$ ]]; then
      obj=$(jq -n --argjson base "$obj" --arg k "$k" --argjson v "$v" '$base + {($k): $v}')
    else
      obj=$(jq -n --argjson base "$obj" --arg k "$k" --arg v "$v" '$base + {($k): $v}')
    fi
  done
  echo "$obj"
}

# ── sessions ──────────────────────────────────────────────────────────────────

cmd_sessions() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits sessions <list|get|create|update|end|context|tasks|notes>"; return 0; }
  case "$sub" in
    list)
      # eits sessions list [--search <q>] [--status <s>] [--project <id>] [--agent <uuid>] [--limit <n>] [--mine] [--include-archived]
      # --agent is mutually exclusive with --search, --status, --project, and --mine
      # --mine is mutually exclusive with --agent, --search, --status, and --project
      local qs="" _agent_flag=0 _other_flag=0 _mine_flag=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --search)  [[ $_agent_flag -eq 1 || $_mine_flag -eq 1 ]] && die "--search cannot combine with --agent or --mine"; _other_flag=1; qs="${qs}&q=$(printf '%s' "$2" | jq -Rr @uri)"; shift 2 ;;
          --status)  [[ $_agent_flag -eq 1 || $_mine_flag -eq 1 ]] && die "--status cannot combine with --agent or --mine"; _other_flag=1; qs="${qs}&status=$2";     shift 2 ;;
          --project) [[ $_agent_flag -eq 1 || $_mine_flag -eq 1 ]] && die "--project cannot combine with --agent or --mine"; _other_flag=1; qs="${qs}&project_id=$2"; shift 2 ;;
          --agent)   [[ $_other_flag -eq 1 || $_mine_flag -eq 1 ]] && die "--agent is mutually exclusive with --search, --status, --project, and --mine"; _agent_flag=1; qs="${qs}&agent_id=$2"; shift 2 ;;
          --mine)    [[ $_agent_flag -eq 1 || $_other_flag -eq 1 ]] && die "--mine cannot combine with --agent, --search, --status, and --project"; _mine_flag=1; local _mine="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"; [[ -n "$_mine" ]] || die "--mine requires EITS_SESSION_UUID or EITS_SESSION_ID to be set"; qs="${qs}&session_id=$_mine"; shift ;;
          --limit)   qs="${qs}&limit=$2";      shift 2 ;;
          --include-archived) qs="${qs}&include_archived=true"; shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/sessions?${qs#&}" | jq .
      ;;
    tasks)
      # eits sessions tasks <uuid>
      local uuid="${1:-}"; need uuid
      _curl "$BASE_URL/tasks?session_id=$uuid" | jq .
      ;;
    notes)
      # eits sessions notes <uuid>
      local uuid="${1:-}"; need uuid
      _curl "$BASE_URL/notes?session_id=$uuid" | jq .
      ;;
    get)
      local uuid="${1:-}"; need uuid
      [[ "$uuid" == "self" ]] && { uuid="${EITS_SESSION_UUID:-}"; [[ -n "$uuid" ]] || die "EITS_SESSION_UUID is not set"; }
      _get "/sessions/$uuid"
      ;;
    create)
      # eits sessions create --session-id <uuid> [--name <n>] [--description <d>] [--project <p>] [--model <m>] [--entrypoint <e>]
      local session_id="" name="" description="" project_name="" model="" entrypoint=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --session-id)  session_id="$2";   shift 2 ;;
          --name)        name="$2";         shift 2 ;;
          --description) description="$2";  shift 2 ;;
          --project)     project_name="$2"; shift 2 ;;
          --model)       model="$2";        shift 2 ;;
          --entrypoint)  entrypoint="$2";   shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need session_id
      _post "/sessions" "$(json session_id "$session_id" name "$name" description "$description" project_name "$project_name" model "$model" entrypoint "$entrypoint")"
      ;;
    update)
      # eits sessions update <uuid> [--status <status>] [--intent <text>] [--entrypoint <e>] [--name <name>] [--description <desc>] [--clear-entrypoint] [--ended-at <ISO8601>]
      local uuid="${1:-}"; need uuid; shift
      [[ "$uuid" == "self" ]] && { uuid="${EITS_SESSION_UUID:-}"; [[ -n "$uuid" ]] || die "EITS_SESSION_UUID is not set"; }
      local status="" intent="" entrypoint="" name="" description="" clear_entrypoint="" ended_at=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --status)      status="$2";      shift 2 ;;
          --intent)      intent="$2";      shift 2 ;;
          --entrypoint)  entrypoint="$2";  shift 2 ;;
          --name)        name="$2";        shift 2 ;;
          --description) description="$2"; shift 2 ;;
          --clear-entrypoint) clear_entrypoint="true"; shift ;;
          --ended-at)    ended_at="$2";    shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _patch "/sessions/$uuid" "$(json status "$status" intent "$intent" entrypoint "$entrypoint" name "$name" description "$description" clear_entrypoint "$clear_entrypoint" ended_at "$ended_at")"
      ;;
    end)
      # eits sessions end <uuid> [--final-status <completed|failed|waiting>]
      local uuid="${1:-}"; need uuid; shift
      local final_status=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --final-status) final_status="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      if [[ -n "$final_status" ]]; then
        _post "/sessions/$uuid/end" "$(json final_status "$final_status")"
      else
        _post "/sessions/$uuid/end" '{}'
      fi
      ;;
    context)
      # eits sessions context <uuid>                                    (GET)
      # eits sessions context <uuid> --text <text> [--metadata <json>]  (PATCH)
      # eits sessions context <uuid> --from-stdin [--metadata <json>]   (PATCH; body from stdin)
      local uuid="${1:-}"; need uuid; shift || true
      local text="" from_stdin=0 metadata=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --text)       text="$2"; shift 2 ;;
          --from-stdin) from_stdin=1; shift ;;
          --metadata)   metadata="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      if [[ $from_stdin -eq 1 ]]; then
        text="$(cat)"
      fi
      if [[ -n "$text" ]]; then
        if [[ -n "$metadata" ]]; then
          _patch "/sessions/$uuid/context" "$(jq -n --arg c "$text" --argjson m "$metadata" '{context: $c, metadata: $m}')"
        else
          _patch "/sessions/$uuid/context" "$(jq -n --arg c "$text" '{context: $c}')"
        fi
      else
        _get "/sessions/$uuid/context"
      fi
      ;;
    *)
      echo "usage: eits sessions <list|get|create|update|end|context|tasks|notes>"
      ;;
  esac
}

# ── tasks ─────────────────────────────────────────────────────────────────────

cmd_tasks() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits tasks <list|get|create|update|done|begin|complete|annotate|start|claim|delete|link-session|unlink-session> [--mine] [--quiet]"; return 0; }
  case "$sub" in
    list)
      # eits tasks list [--project <id>] [--session <uuid>] [--agent <uuid>] [--q <query>] [--search <query>] [--state <id>] [--state-name <name>] [--limit <n>] [--mine]
      local qs="" _session_flag=0 _mine_flag=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) qs="${qs}&project_id=$2"; shift 2 ;;
          --session) [[ $_mine_flag -eq 1 ]] && die "--mine and --session are mutually exclusive"; _session_flag=1; qs="${qs}&session_id=$2"; shift 2 ;;
          --agent)   qs="${qs}&agent_id=$2";   shift 2 ;;
          --q|--search) qs="${qs}&q=$(printf '%s' "$2" | jq -Rr @uri)"; shift 2 ;;
          --state)   qs="${qs}&state_id=$2";   shift 2 ;;
          --state-name)
            case "$2" in
              todo)          qs="${qs}&state_id=1"; shift 2 ;;
              in-progress|start) qs="${qs}&state_id=2"; shift 2 ;;
              done)          qs="${qs}&state_id=3"; shift 2 ;;
              in-review|review) qs="${qs}&state_id=4"; shift 2 ;;
              *) die "unknown state name: $2" ;;
            esac ;;
          --limit)   qs="${qs}&limit=$2";      shift 2 ;;
          --mine)    [[ $_session_flag -eq 1 ]] && die "--mine and --session are mutually exclusive"; _mine_flag=1; local _mine="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"; [[ -n "$_mine" ]] || die "--mine requires EITS_SESSION_UUID or EITS_SESSION_ID to be set"; qs="${qs}&session_id=$_mine"; shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/tasks?${qs#&}" | jq .
      ;;
    get)
      local id="${1:-}"; need id
      _get "/tasks/$id"
      ;;
    create)
      # eits tasks create --title <t> [--description <d>] [--project <id>] [--priority <p>] [--session <uuid>] [--agent <uuid>] [--tags <id1,id2,...>] [--team <id>] [--due-at <ISO8601>]
      # Defaults: --agent from $EITS_AGENT_UUID, --project from $EITS_PROJECT_ID, --session from $EITS_SESSION_UUID (falls back to $EITS_SESSION_ID)
      local title="" description="" project_id="${EITS_PROJECT_ID:-}" priority="" session_id="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}" agent_id="${EITS_AGENT_UUID:-}" tags="" team_id="" due_at=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --title)       title="$2";       shift 2 ;;
          --description) description="$2"; shift 2 ;;
          --project)     project_id="$2";  shift 2 ;;
          --priority)    priority="$2";    shift 2 ;;
          --session)     session_id="$2";  shift 2 ;;
          --agent)       agent_id="$2";    shift 2 ;;
          --tags)        tags="$2";        shift 2 ;;
          --team)        team_id="$2";     shift 2 ;;
          --due-at)      due_at="$2";      shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need title
      local body
      body="$(json title "$title" description "$description" project_id "$project_id" priority "$priority" session_id "$session_id" agent_id "$agent_id" team_id "$team_id" due_at "$due_at")"
      if [[ -n "$tags" ]]; then
        local tag_array
        tag_array=$(echo "$tags" | jq -R 'split(",") | map(tonumber)')
        body=$(echo "$body" | jq --argjson ids "$tag_array" '. + {tag_ids: $ids}')
      fi
      _post "/tasks" "$body"
      ;;
    update)
      # eits tasks update <id> [--state <id>] [--state-name <done|start>] [--priority <p>] [--description <d>] [--title <t>] [--due-at <ISO8601>]
      local id="${1:-}"; need id; shift
      local updates="{}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --state)
            if [[ "$2" =~ ^[0-9]+$ ]]; then
              updates=$(echo "$updates" | jq --argjson v "$2" '. + {state_id: $v}')
            else
              updates=$(echo "$updates" | jq --arg v "$2" '. + {state: $v}')
            fi
            shift 2 ;;
          --state-name)  updates=$(echo "$updates" | jq --arg v "$2" '. + {state: $v}');       shift 2 ;;
          --priority)    updates=$(echo "$updates" | jq --arg v "$2" '. + {priority: $v}');    shift 2 ;;
          --description) updates=$(echo "$updates" | jq --arg v "$2" '. + {description: $v}'); shift 2 ;;
          --title)       updates=$(echo "$updates" | jq --arg v "$2" '. + {title: $v}');       shift 2 ;;
          --due-at)      updates=$(echo "$updates" | jq --arg v "$2" '. + {due_at: $v}');      shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _patch "/tasks/$id" "${updates}"
      ;;
    done)
      local id="${1:-}"; need id
      _patch "/tasks/$id" '{"state":"done"}'
      ;;
    start|claim)
      local id="${1:-}"; need id
      # Auto-link current session atomically with the state transition
      local _sess="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"
      _patch "/tasks/$id" "$(json state "start" session_id "$_sess")"
      # Belt-and-suspenders: explicit follow-up link in case the session wasn't
      # in the DB yet when the PATCH was processed (silent no-op if already linked)
      if [[ -n "$_sess" ]]; then
        _curl -sf -X POST -H "Content-Type: application/json" \
          -d "$(json session_id "$_sess")" \
          "$BASE_URL/tasks/$id/sessions" >/dev/null 2>&1 || true
      fi
      ;;
    delete)
      local id="${1:-}"; need id
      _delete "/tasks/$id"
      ;;
    annotate)
      # eits tasks annotate <id> --body <text> [--title <t>]
      local id="${1:-}"; need id; shift
      local body="" title=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --body)  body="$2";  shift 2 ;;
          --title) title="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need body
      _post "/tasks/$id/annotations" "$(json body "$body" title "$title")"
      ;;
    link-session)
      # eits tasks link-session <task_id> [<session_uuid>]
      # session_uuid defaults to $EITS_SESSION_UUID (falls back to $EITS_SESSION_ID) if not provided
      local id="${1:-}"; need id; shift
      local session_id="${1:-${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}}"
      [[ -n "$session_id" ]] || die "session_uuid is required (or set EITS_SESSION_UUID / EITS_SESSION_ID)"
      _post "/tasks/$id/sessions" "$(json session_id "$session_id")"
      ;;
    unlink-session)
      local id="${1:-}"; need id; shift
      local session_id="${1:-}"; need session_id
      _delete "/tasks/$id/sessions/$session_id"
      ;;
    complete)
      # eits tasks complete <id> [<message>] [--message <text>]
      # Delegates to POST /tasks/:id/complete — atomic annotate+done via server transaction.
      local id="${1:-}"; need id; shift
      local message=""
      # Check if next arg is not a flag and treat it as the message
      if [[ $# -gt 0 && "$1" != --* ]]; then
        message="$1"
        shift
      fi
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --message) message="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need message
      _post "/tasks/$id/complete" "$(json message "$message")"
      ;;
    begin|quick)
      # eits tasks begin --title <t> [--description <d>] [--project <id>] [--priority <p>] [--quiet|-q]
      # Creates a task, links the current session, and starts it — all in one command.
      local title="" description="" project_id="${EITS_PROJECT_ID:-}" priority="" quiet=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --title)       title="$2";       shift 2 ;;
          --description) description="$2"; shift 2 ;;
          --project)     project_id="$2";  shift 2 ;;
          --priority)    priority="$2";    shift 2 ;;
          --quiet|-q)    quiet=1;          shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need title
      local _sess="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"
      local body
      body="$(json title "$title" description "$description" project_id "$project_id" priority "$priority" session_id "$_sess")"
      local create_resp task_id
      create_resp=$(_post "/tasks" "$body")
      task_id=$(echo "$create_resp" | jq -r '.task_id // empty')
      [[ -n "$task_id" ]] || die "task creation failed"
      if [[ $quiet -eq 0 ]]; then
        echo "$create_resp"
      else
        echo "$task_id"
      fi
      _patch "/tasks/$task_id" "$(json state "start" session_id "$_sess")" > /dev/null
      if [[ -n "$_sess" ]]; then
        _curl -sf -X POST -H "Content-Type: application/json" \
          -d "$(json session_id "$_sess")" \
          "$BASE_URL/tasks/$task_id/sessions" >/dev/null 2>&1 || true
      fi
      ;;
    tag)
      # eits tasks tag <task_id> <tag_id>
      local task_id="${1:-}"; need task_id; shift
      local tag_id="${1:-}"; need tag_id
      _post "/tasks/$task_id/tags" "$(json tag_id "$tag_id")"
      ;;
    *)
      echo "usage: eits tasks <list|get|create|update|done|begin|start|claim|complete|delete|annotate|link-session|unlink-session|tag> [--mine] [--title] [--quiet]"
      ;;
  esac
}

# ── notes ─────────────────────────────────────────────────────────────────────

cmd_notes() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits notes <list|search|get|create|update|add>"; return 0; }
  case "$sub" in
    list)
      # eits notes list [--q <query>] [--search <query>] [--session <uuid>] [--limit <n>] [--mine]
      # --mine is mutually exclusive with --session
      local qs="" _session_flag=0 _mine_flag=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --q|--search) qs="${qs}&q=$(printf '%s' "$2" | jq -Rr @uri)"; shift 2 ;;
          --session) [[ $_mine_flag -eq 1 ]] && die "--session and --mine are mutually exclusive"; _session_flag=1; qs="${qs}&session_id=$2"; shift 2 ;;
          --mine)    [[ $_session_flag -eq 1 ]] && die "--mine and --session are mutually exclusive"; _mine_flag=1; local _mine="${EITS_SESSION_UUID:-}"; [[ -n "$_mine" ]] || die "--mine requires EITS_SESSION_UUID to be set"; qs="${qs}&session_id=$_mine"; shift ;;
          --limit)   qs="${qs}&limit=$2";      shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/notes?${qs#&}" | jq .
      ;;
    get)
      local id="${1:-}"; need id
      _get "/notes/$id"
      ;;
    create)
      # eits notes create --parent-type <session|task|agent> --parent-id <id> --body <text> [--title <t>] [--starred]
      local parent_type="" parent_id="" body="" title="" starred="0"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --parent-type) parent_type="$2"; shift 2 ;;
          --parent-id)   parent_id="$2";   shift 2 ;;
          --body)        body="$2";        shift 2 ;;
          --title)       title="$2";       shift 2 ;;
          --starred)     starred="1";      shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need parent_type; need parent_id; need body
      _post "/notes" "$(json parent_type "$parent_type" parent_id "$parent_id" body "$body" title "$title" starred "$starred")"
      ;;
    update)
      # eits notes update <id> [--body <text>] [--title <t>] [--starred]
      local id="${1:-}"; need id; shift
      local updates="{}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --body)    updates=$(echo "$updates" | jq --arg v "$2" '. + {body: $v}');    shift 2 ;;
          --title)   updates=$(echo "$updates" | jq --arg v "$2" '. + {title: $v}');   shift 2 ;;
          --starred) updates=$(echo "$updates" | jq '. + {starred: 1}');                   shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _patch "/notes/$id" "${updates}"
      ;;
    search)
      # eits notes search <query>
      local query="${1:-}"; need query
      _curl "$BASE_URL/notes?q=$(printf '%s' "$query" | jq -Rr @uri)" | jq .
      ;;
    add)
      # eits notes add --body <text> [--title <t>]
      # Creates a note attached to the current session (parent_type=session, parent_id=$EITS_SESSION_UUID)
      local body="" title=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --body)  body="$2";  shift 2 ;;
          --title) title="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need body
      local parent_id="${EITS_SESSION_UUID:-}"; [[ -n "$parent_id" ]] || die "EITS_SESSION_UUID is not set"
      _post "/notes" "$(json parent_type "session" parent_id "$parent_id" body "$body" title "$title")"
      ;;
    *)
      echo "usage: eits notes <list|search|get|create|update|add>"
      ;;
  esac
}

# ── projects ──────────────────────────────────────────────────────────────────

cmd_projects() {
  local sub="${1:-}"; shift || true
  [[ "${sub:-}" == "--help" || "${sub:-}" == "-h" ]] && { echo "usage: eits projects <list|get|create>"; return 0; }
  case "$sub" in
    list)
      _get "/projects"
      ;;
    get)
      local id="${1:-}"; need id
      _get "/projects/$id"
      ;;
    create)
      # eits projects create --name <n> --path <p> [--slug <s>] [--remote <url>] [--git-remote <url>] [--repo-url <url>] [--branch <b>] [--active|--inactive]
      local name="" path="" slug="" remote_url="" git_remote="" repo_url="" branch="" active=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)       name="$2";       shift 2 ;;
          --path)       path="$2";       shift 2 ;;
          --slug)       slug="$2";       shift 2 ;;
          --remote)     remote_url="$2"; shift 2 ;;
          --git-remote) git_remote="$2"; shift 2 ;;
          --repo-url)   repo_url="$2";   shift 2 ;;
          --branch)     branch="$2";     shift 2 ;;
          --active)     active="true";   shift ;;
          --inactive)   active="false";  shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need name; need path
      _post "/projects" "$(json name "$name" path "$path" slug "$slug" remote_url "$remote_url" git_remote "$git_remote" repo_url "$repo_url" branch "$branch" active "$active")"
      ;;
    *)
      echo "usage: eits projects <list|get|create>"
      ;;
  esac
}

# ── agents ────────────────────────────────────────────────────────────────────

cmd_agents() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits agents <list|get|spawn>"; return 0; }
  case "$sub" in
    list)
      # eits agents list [--project <id>] [--status <status>] [--limit <n>]
      local qs=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) qs="${qs}&project_id=$2"; shift 2 ;;
          --status)  qs="${qs}&status=$2";     shift 2 ;;
          --limit)   qs="${qs}&limit=$2";      shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/agents?${qs#&}" | jq .
      ;;
    get)
      local id="${1:-}"; need id
      _get "/agents/$id"
      ;;
    spawn)
      # eits agents spawn --instructions <text> [--model <m>] [--provider <p>]
      #   [--project-id <n>] [--project-path <path>] [--worktree <branch>]
      #   [--effort-level <level>] [--parent-session-id <n>] [--parent-agent-id <n>]
      #   [--team-name <name>] [--member-name <alias>] [--agent <name>] [--name <n>] [--yolo]
      local instructions="" model="" provider="" project_id="${EITS_PROJECT_ID:-}" project_path="${PWD:-}"
      local worktree="" effort_level="" parent_session_id="" parent_agent_id=""
      local team_name="" member_name="" agent_name="" session_name="" bypass_sandbox="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --instructions)      instructions="$2";      shift 2 ;;
          --model)             model="$2";             shift 2 ;;
          --provider)          provider="$2";          shift 2 ;;
          --project-id)        project_id="$2";        shift 2 ;;
          --project-path)      project_path="$2";      shift 2 ;;
          --worktree)          worktree="$2";          shift 2 ;;
          --effort-level)      effort_level="$2";      shift 2 ;;
          --parent-session-id) parent_session_id="$2"; shift 2 ;;
          --parent-agent-id)   parent_agent_id="$2";   shift 2 ;;
          --team-name)         team_name="$2";         shift 2 ;;
          --member-name)       member_name="$2";       shift 2 ;;
          --agent)             agent_name="$2";        shift 2 ;;
          --name)              session_name="$2";      shift 2 ;;
          --yolo)              bypass_sandbox="true";  shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need instructions
      local payload
      payload=$(jq -n \
        --arg     instructions      "$instructions" \
        --arg     model             "$model" \
        --arg     provider          "$provider" \
        --arg     project_path      "$project_path" \
        --arg     worktree          "$worktree" \
        --arg     effort_level      "$effort_level" \
        --arg     team_name         "$team_name" \
        --arg     member_name       "$member_name" \
        --arg     agent             "$agent_name" \
        --arg     name              "$session_name" \
        --argjson project_id        "${project_id:-null}" \
        --argjson parent_session_id "${parent_session_id:-null}" \
        --argjson parent_agent_id   "${parent_agent_id:-null}" \
        --argjson bypass_sandbox    "$bypass_sandbox" \
        '{instructions: $instructions}
         + (if $model             != "" then {model: $model}                           else {} end)
         + (if $provider          != "" then {provider: $provider}                     else {} end)
         + (if $project_path      != "" then {project_path: $project_path}             else {} end)
         + (if $worktree          != "" then {worktree: $worktree}                     else {} end)
         + (if $effort_level      != "" then {effort_level: $effort_level}             else {} end)
         + (if $team_name         != "" then {team_name: $team_name}                   else {} end)
         + (if $member_name       != "" then {member_name: $member_name}               else {} end)
         + (if $agent             != "" then {agent: $agent}                           else {} end)
         + (if $name              != "" then {name: $name}                             else {} end)
         + (if $project_id        != null then {project_id: $project_id}               else {} end)
         + (if $parent_session_id != null then {parent_session_id: $parent_session_id} else {} end)
         + (if $parent_agent_id   != null then {parent_agent_id: $parent_agent_id}     else {} end)
         + (if $bypass_sandbox           then {bypass_sandbox: true}                   else {} end)')
      _post "/agents" "$payload"
      ;;
    *)
      echo "usage: eits agents <list|get|spawn>"
      ;;
  esac
}

# ── commits ───────────────────────────────────────────────────────────────────

cmd_commits() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits commits <list|create>"; return 0; }
  case "$sub" in
    list)
      # eits commits list [--session <uuid>] [--agent <uuid>] [--mine] [--limit <n>]
      # --mine, --session, and --agent are mutually exclusive
      local qs="" _session_flag=0 _mine_flag=0 _agent_flag=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --session) [[ $_mine_flag -eq 1 || $_agent_flag -eq 1 ]] && die "--session is mutually exclusive with --mine and --agent"; _session_flag=1; qs="${qs}&session_id=$2"; shift 2 ;;
          --agent)   [[ $_mine_flag -eq 1 || $_session_flag -eq 1 ]] && die "--agent is mutually exclusive with --mine and --session"; _agent_flag=1; qs="${qs}&agent_id=$2"; shift 2 ;;
          --mine)    [[ $_session_flag -eq 1 || $_agent_flag -eq 1 ]] && die "--mine is mutually exclusive with --session and --agent"; _mine_flag=1; local _mine="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"; [[ -n "$_mine" ]] || die "--mine requires EITS_SESSION_UUID or EITS_SESSION_ID"; qs="${qs}&session_id=$_mine"; shift ;;
          --limit)   qs="${qs}&limit=$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/commits?${qs#&}" | jq .
      ;;
    create)
      # eits commits create [--agent <uuid>] --hash <h1> [--hash <h2>] [--message <m>] ...
      # --agent defaults to $EITS_AGENT_UUID
      local agent_id="${EITS_AGENT_UUID:-}" hashes=() messages=()
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --agent)   agent_id="$2";        shift 2 ;;
          --hash)    hashes+=("$2");       shift 2 ;;
          --message) messages+=("$2");     shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      [[ -n "$agent_id" ]] || die "agent_id is required (or set EITS_AGENT_UUID)"
      if [[ ${#hashes[@]} -eq 0 ]]; then
        local auto_hash
        auto_hash=$(git rev-parse HEAD 2>/dev/null) || die "not in a git repo; use --hash"
        hashes=("$auto_hash")
        if [[ ${#messages[@]} -eq 0 ]]; then
          local auto_msg
          auto_msg=$(git log -1 --format=%s 2>/dev/null || echo "")
          [[ -n "$auto_msg" ]] && messages=("$auto_msg")
        fi
      fi
      local hashes_json; hashes_json=$(printf '%s\n' "${hashes[@]}" | jq -R . | jq -s .)
      local payload
      if [[ ${#messages[@]} -gt 0 ]]; then
        local msgs_json; msgs_json=$(printf '%s\n' "${messages[@]}" | jq -R . | jq -s .)
        payload=$(jq -n --arg a "$agent_id" --argjson h "$hashes_json" --argjson m "$msgs_json" \
          '{agent_id: $a, commit_hashes: $h, commit_messages: $m}')
      else
        payload=$(jq -n --arg a "$agent_id" --argjson h "$hashes_json" \
          '{agent_id: $a, commit_hashes: $h}')
      fi
      _post "/commits" "$payload"
      ;;
    *)
      echo "usage: eits commits <list|create>"
      ;;
  esac
}

# ── jobs ──────────────────────────────────────────────────────────────────────

cmd_jobs() {
  local sub="${1:-}"; shift || true
  [[ "${sub:-}" == "--help" || "${sub:-}" == "-h" ]] && { echo "usage: eits jobs <list|get|create|update|run|delete>"; return 0; }
  case "$sub" in
    list)
      # eits jobs list [--project <id>] [--global]
      local qs=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) qs="${qs}&project_id=$2"; shift 2 ;;
          --global)  qs="${qs}&global=true";   shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/jobs?${qs#&}" | jq .
      ;;
    get)
      local id="${1:-}"; need id
      _get "/jobs/$id"
      ;;
    create)
      # eits jobs create --name <n> --job-type <type> --schedule-type <type> --schedule-value <val> [--description <d>] [--config <json>] [--enabled] [--project <id>]
      local name="" description="" job_type="" schedule_type="" schedule_value="" config="" enabled="" project_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)           name="$2";           shift 2 ;;
          --description)    description="$2";    shift 2 ;;
          --job-type)       job_type="$2";       shift 2 ;;
          --schedule-type)  schedule_type="$2";  shift 2 ;;
          --schedule-value) schedule_value="$2"; shift 2 ;;
          --config)         config="$2";         shift 2 ;;
          --enabled)        enabled="true";      shift ;;
          --project)        project_id="$2";     shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need name
      need job_type
      need schedule_type
      need schedule_value
      local body
      body="$(json name "$name" description "$description" job_type "$job_type" schedule_type "$schedule_type" schedule_value "$schedule_value" enabled "$enabled" project_id "$project_id")"
      if [[ -n "$config" ]]; then
        body=$(echo "$body" | jq --argjson c "$config" '. + {config: $c}')
      fi
      _post "/jobs" "$body"
      ;;
    update)
      # eits jobs update <id> [--name <n>] [--description <d>] [--job-type <type>] [--schedule-type <type>] [--schedule-value <val>] [--config <json>] [--enabled|--disabled] [--project <id>]
      local id="${1:-}"; need id; shift
      local updates="{}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)           updates=$(echo "$updates" | jq --arg v "$2" '. + {name: $v}');            shift 2 ;;
          --description)    updates=$(echo "$updates" | jq --arg v "$2" '. + {description: $v}');    shift 2 ;;
          --job-type)       updates=$(echo "$updates" | jq --arg v "$2" '. + {job_type: $v}');       shift 2 ;;
          --schedule-type)  updates=$(echo "$updates" | jq --arg v "$2" '. + {schedule_type: $v}');  shift 2 ;;
          --schedule-value) updates=$(echo "$updates" | jq --arg v "$2" '. + {schedule_value: $v}'); shift 2 ;;
          --config)         updates=$(echo "$updates" | jq --argjson v "$2" '. + {config: $v}');     shift 2 ;;
          --enabled)        updates=$(echo "$updates" | jq '. + {enabled: true}');                   shift ;;
          --disabled)       updates=$(echo "$updates" | jq '. + {enabled: false}');                  shift ;;
          --project)        updates=$(echo "$updates" | jq --arg v "$2" '. + {project_id: $v}');     shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _patch "/jobs/$id" "$updates"
      ;;
    run)
      local id="${1:-}"; need id
      _post "/jobs/$id/run" '{}'
      ;;
    delete)
      local id="${1:-}"; need id
      _delete "/jobs/$id"
      ;;
    *)
      echo "usage: eits jobs <list|get|create|update|run|delete>"
      ;;
  esac
}

# ── dm ────────────────────────────────────────────────────────────────────────

cmd_dm() {
  # eits dm [--from <session_id|uuid>] --to <session_id|uuid> --message <text> [--response-required]
  # --from defaults to $EITS_SESSION_UUID or $EITS_SESSION_ID when omitted
  local from="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}" to="" message="" response_required="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from)              from="$2";              shift 2 ;;
      --to)                to="$2";                shift 2 ;;
      --message|-m)        message="$2";           shift 2 ;;
      --response-required) response_required="true"; shift ;;
      *) die "unknown flag: $1" ;;
    esac
  done
  need from; need to; need message

  local payload
  payload=$(jq -n --arg f "$from" --arg t "$to" --arg m "$message" --argjson r "$response_required" \
    '{from_session_id: $f, to_session_id: $t, message: $m, response_required: $r}')
  _post "/dm" "$payload"
}

# ── timer ─────────────────────────────────────────────────────────────────────

cmd_timer() {
  local sub="${1:-}"; shift || true
  [[ "${sub:-}" == "--help" || "${sub:-}" == "-h" ]] && { echo "usage: eits timer <show|set|cancel> [<session_id>] [options]"; return 0; }
  case "$sub" in
    show|get)
      local session="self"
      if [[ $# -gt 0 && "$1" != --* ]]; then session="$1"; shift; fi
      [[ "$session" == "self" ]] && session="${EITS_SESSION_UUID:-}"
      need session
      _get "/sessions/$session/timer"
      ;;
    set|schedule)
      local session="self"
      if [[ $# -gt 0 && "$1" != --* ]]; then session="$1"; shift; fi
      [[ "$session" == "self" ]] && session="${EITS_SESSION_UUID:-}"
      need session
      local preset="" delay_ms="" mode="" message=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --preset)     preset="$2";    shift 2 ;;
          --delay-ms|--delay) delay_ms="$2"; shift 2 ;;
          --mode)       mode="$2";      shift 2 ;;
          --message|-m) message="$2";   shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      [[ -n "$preset" || -n "$delay_ms" ]] || die "--preset or --delay-ms is required"
      local body="{}"
      [[ -n "$preset" ]]   && body=$(echo "$body" | jq --arg v "$preset"   '. + {preset: $v}')
      [[ -n "$delay_ms" ]] && body=$(echo "$body" | jq --argjson v "$delay_ms" '. + {delay_ms: $v}')
      [[ -n "$mode" ]]     && body=$(echo "$body" | jq --arg v "$mode"     '. + {mode: $v}')
      [[ -n "$message" ]]  && body=$(echo "$body" | jq --arg v "$message"  '. + {message: $v}')
      _post "/sessions/$session/timer" "$body"
      ;;
    cancel)
      local session="self"
      if [[ $# -gt 0 && "$1" != --* ]]; then session="$1"; shift; fi
      [[ "$session" == "self" ]] && session="${EITS_SESSION_UUID:-}"
      need session
      _delete "/sessions/$session/timer"
      ;;
    *)
      cat <<USAGE
usage: eits timer <show|set|cancel> [<session_id>] [options]

session_id defaults to self (\$EITS_SESSION_UUID) when omitted.

Subcommands:
  show   [<session_id>]                                Show active timer (404 if none)
  set    [<session_id>] --preset <5m|10m|15m|30m|1h>  Schedule one-shot timer
  set    [<session_id>] --delay-ms <N> [--mode once|repeating] [--message <text>]
  cancel [<session_id>]                                Cancel active timer

Examples:
  eits timer set --preset 15m            # wake self up in 15 min
  eits timer set --preset 30m --mode repeating
  eits timer set 1234 --delay-ms 300000 --message "check in"
  eits timer show
  eits timer cancel
USAGE
      ;;
  esac
}

# ── channels ──────────────────────────────────────────────────────────────────

cmd_channels() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits channels <list|send|messages>"; return 0; }
  case "$sub" in
    list)
      local project_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) project_id="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      if [[ -n "$project_id" ]]; then
        _curl "$BASE_URL/channels?project_id=$project_id" | jq .
      else
        _get "/channels"
      fi
      ;;
    send)
      # eits channels send <channel_id> --session <uuid> --body <text>
      # --session defaults to $EITS_SESSION_UUID if not provided
      local channel_id="${1:-}"; need channel_id; shift
      local session_id="${EITS_SESSION_UUID:-}" body=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --session) session_id="$2"; shift 2 ;;
          --body|-m) body="$2";       shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need session_id; need body
      _post "/channels/$channel_id/messages" "$(json session_id "$session_id" body "$body")"
      ;;
    messages)
      # eits channels messages <channel_id> [--limit N]
      local channel_id="${1:-}"; need channel_id; shift
      local limit="20"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --limit|-n) limit="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/channels/$channel_id/messages?limit=$limit" | jq .
      ;;
    *)
      cat <<USAGE
usage: eits channels <subcommand>

Subcommands:
  list     [--project <id>]                         List channels (optionally filter by project)
  send     <channel_id> --session <id> --body <text> Send a message to a channel
  messages <channel_id> [--limit|-n <N>]            Get last N messages (default 20, max 200)

Examples:
  eits channels list
  eits channels list --project 1
  eits channels send 1 --session 1179 --body "hello"
  eits channels messages 1
  eits channels messages 1 -n 5
USAGE
      ;;
  esac
}

# ── notifications ─────────────────────────────────────────────────────────────

cmd_notifications() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits notifications create --title <t> [--body <b>] [--category agent|job|system] [--resource-type <type>] [--resource-id <id>]"; return 0; }
  case "$sub" in
    create)
      # eits notifications create --title <t> [--body <b>] [--category <agent|job|system>] [--resource-type <type>] [--resource-id <id>]
      # --category maps to the API's category field (agent, job, system; default: system)
      # --resource-type and --resource-id link the notification to a resource
      local title="" body="" category="" resource_type="" resource_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --title)         title="$2";         shift 2 ;;
          --body)          body="$2";          shift 2 ;;
          --category)      category="$2";      shift 2 ;;
          --resource-type) resource_type="$2"; shift 2 ;;
          --resource-id)   resource_id="$2";   shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need title
      _post "/notifications" "$(json title "$title" body "$body" category "$category" resource_type "$resource_type" resource_id "$resource_id")"
      ;;
    *)
      echo "usage: eits notifications <create>"
      ;;
  esac
}

# ── prompts ───────────────────────────────────────────────────────────────────

cmd_prompts() {
  local sub="${1:-}"; shift || true
  [[ "${sub:-}" == "--help" || "${sub:-}" == "-h" ]] && { echo "usage: eits prompts <list|get|create>"; return 0; }
  case "$sub" in
    list)
      # eits prompts list [--query <q>] [--project <id>]
      local qs=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --query|-q)  qs="${qs}&query=$(printf '%s' "$2" | jq -Rr @uri)"; shift 2 ;;
          --project)   qs="${qs}&project_id=$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/prompts?${qs#&}" | jq .
      ;;
    get)
      # eits prompts get <id> [--project <id>] [--no-text]
      local id="${1:-}"; need id; shift
      local qs=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) qs="${qs}&project_id=$2"; shift 2 ;;
          --no-text) qs="${qs}&include_text=false"; shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/prompts/$id?${qs#&}" | jq .
      ;;
    create)
      # eits prompts create --name <n> --slug <s> --prompt-text <t> [--description <d>] [--project <id>] [--tags <json>] [--created-by <name>]
      local name="" slug="" prompt_text="" description="" project_id="" tags="" created_by=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)        name="$2";        shift 2 ;;
          --slug)        slug="$2";        shift 2 ;;
          --prompt-text) prompt_text="$2"; shift 2 ;;
          --description) description="$2"; shift 2 ;;
          --project)     project_id="$2";  shift 2 ;;
          --tags)        tags="$2";        shift 2 ;;
          --created-by)  created_by="$2";  shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need name; need slug; need prompt_text
      local body
      body="$(json name "$name" slug "$slug" prompt_text "$prompt_text" description "$description" project_id "$project_id" created_by "$created_by")"
      if [[ -n "$tags" ]]; then
        body=$(echo "$body" | jq --argjson t "$tags" '. + {tags: $t}')
      fi
      _post "/prompts" "$body"
      ;;
    *)
      echo "usage: eits prompts <list|get|create>"
      ;;
  esac
}

# ── teams ─────────────────────────────────────────────────────────────────────

cmd_teams() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits teams <list|get|create|delete|members|join|status|update-member|done-self|leave|broadcast|my-teams>"; return 0; }
  case "$sub" in
    list)
      local project_id="" status=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) project_id="$2"; shift 2 ;;
          --status)  status="$2";     shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      local qs=""
      [[ -n "$project_id" ]] && qs="${qs}&project_id=${project_id}"
      [[ -n "$status"     ]] && qs="${qs}&status=${status}"
      _get "/teams${qs:+?${qs:1}}"
      ;;
    get)
      local id="${1:-}"; need id
      _get "/teams/$id"
      ;;
    create)
      local name="" description="" project_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)        name="$2";        shift 2 ;;
          --description) description="$2"; shift 2 ;;
          --project)     project_id="$2";  shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need name
      _post "/teams" "$(json name "$name" description "$description" project_id "$project_id")"
      ;;
    delete)
      local id="${1:-}"; need id
      _delete "/teams/$id"
      ;;
    members)
      local id="${1:-}"; need id
      _get "/teams/$id/members"
      ;;
    join)
      local team_id="${1:-}"; need team_id; shift
      local name="" role="" session_id="" agent_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)    name="$2";       shift 2 ;;
          --role)    role="$2";       shift 2 ;;
          --session) session_id="$2"; shift 2 ;;
          --agent)   agent_id="$2";   shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need name
      session_id="${session_id:-${EITS_SESSION_UUID:-}}"
      _post "/teams/$team_id/members" "$(json name "$name" role "$role" session_id "$session_id" agent_id "$agent_id")"
      ;;
    status)
      # alias for get (includes members inline)
      local id="${1:-}"; need id
      _get "/teams/$id"
      ;;
    update-member)
      local team_id="${1:-}"; need team_id; shift
      local member_id="${1:-}"; need member_id; shift
      local status=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --status) status="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need status
      _patch "/teams/$team_id/members/$member_id" "$(json status "$status")"
      ;;
    done-self)
      # eits teams done-self <team_id>
      # Finds the current session's member in the team and marks them done.
      local team_id="${1:-}"; need team_id
      local session_uuid="${EITS_SESSION_UUID:-}"
      [[ -n "$session_uuid" ]] || die "EITS_SESSION_UUID is required (or set it explicitly)"

      local members_resp
      members_resp=$(_curl "$BASE_URL/teams/$team_id/members") \
        || die "failed to fetch members for team $team_id"

      local member_id
      member_id=$(echo "$members_resp" | jq -r --arg uuid "$session_uuid" \
        '.members[] | select(.session_uuid == $uuid) | .id' 2>/dev/null)

      [[ -n "$member_id" ]] || die "current session not found in team $team_id members"

      _patch "/teams/$team_id/members/$member_id" '{"status":"done"}'
      ;;
    leave)
      local team_id="${1:-}"; need team_id; shift
      local member_id="${1:-}"; need member_id
      _delete "/teams/$team_id/members/$member_id"
      ;;
    broadcast)
      # eits teams broadcast <team_id> --message <text> [--from <session>] [--include-self] [--response-required]
      local team_id="${1:-}"; need team_id; shift
      local from="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}" message="" include_self="false" response_required="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --from)              from="$2";                shift 2 ;;
          --message|-m)        message="$2";             shift 2 ;;
          --include-self)      include_self="true";      shift ;;
          --response-required) response_required="true"; shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need from; need message

      local members_resp
      members_resp=$(_curl "$BASE_URL/teams/$team_id/members") \
        || die "failed to fetch members for team $team_id"

      local targets
      local skip_self; skip_self="$([[ "$include_self" == "true" ]] && echo false || echo true)"
      targets=$(echo "$members_resp" | jq -r --arg self "$from" --argjson skip_self "$skip_self" \
        '.members[] | select(.session_uuid != null) | select(($skip_self | not) or (.session_uuid != $self)) | .session_uuid')

      [[ -z "$targets" ]] && die "no recipients found in team $team_id"

      local sent=0 failed=0 results="[]"
      while IFS= read -r to; do
        [[ -z "$to" ]] && continue
        local payload result dm_exit
        payload=$(jq -n --arg f "$from" --arg t "$to" --arg m "$message" --argjson r "$response_required" \
          '{from_session_id: $f, to_session_id: $t, message: $m, response_required: $r}')
        result=$(_curl -X POST -H "Content-Type: application/json" -d "$payload" "$BASE_URL/dm" 2>&1); dm_exit=$?
        if [[ $dm_exit -eq 0 ]]; then
          sent=$((sent+1))
          local safe_result
          safe_result=$(echo "$result" | jq -c '.' 2>/dev/null || echo '{}')
          results=$(jq -n --argjson base "$results" --arg to "$to" --argjson r "$safe_result" '$base + [{to: $to, ok: true, result: $r}]')
        else
          failed=$((failed+1))
          results=$(jq -n --argjson base "$results" --arg to "$to" --argjson code "$dm_exit" --arg err "$result" \
            '$base + [{to: $to, ok: false, exit_code: $code, error: $err}]')
        fi
      done <<< "$targets"

      jq -n --argjson s "$sent" --argjson f "$failed" --argjson r "$results" \
        '{success: ($f == 0), sent: $s, failed: $f, results: $r}'
      ;;
    my-teams)
      # List teams where the current agent is a member (by EITS_AGENT_UUID)
      local agent_uuid="${EITS_AGENT_UUID:-}"; need agent_uuid
      local resp
      resp=$(_curl "$BASE_URL/teams" | jq .)
      # Filter to teams where agent is a member — requires iterating .teams[]
      echo "$resp" | jq --arg uuid "$agent_uuid" '.teams[] | select(.id) | .id' 2>/dev/null | while read -r tid; do
        local members_resp
        members_resp=$(_curl "$BASE_URL/teams/$tid/members" 2>/dev/null || true)
        if echo "$members_resp" | jq -e --arg uuid "$agent_uuid" '.members[] | select(.agent_uuid == $uuid)' >/dev/null 2>&1; then
          echo "$members_resp" | jq --arg uuid "$agent_uuid" '{team_id: .team_id, member: (.members[] | select(.agent_uuid == $uuid))}'
        fi
      done
      ;;
    *)
      echo "usage: eits teams <list|get|create|delete|members|join|status|update-member|done-self|leave|broadcast|my-teams>"
      ;;
  esac
}

# ── worktree ──────────────────────────────────────────────────────────────────
# NOTE: Scoped to EITS Elixir projects (.claude/worktrees/ layout, mix compile).

cmd_worktree() {
  local subcmd="${1:-}"; shift || true
  [[ "${subcmd:-}" == "--help" || "${subcmd:-}" == "-h" ]] && { echo "usage: eits worktree <create|remove>"; return 0; }
  case "$subcmd" in
    create)
      local branch="${1:-}"; need branch; shift || true
      local project_path="${EITS_PROJECT_PATH:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project-path) project_path="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done

      local wt_path="$project_path/.claude/worktrees/$branch"

      if [[ -d "$wt_path" ]] && [[ -e "$wt_path/.git" ]]; then
        echo "Worktree already exists at $wt_path — reusing"
      else
        echo "Creating worktree: $wt_path (branch: $branch)"
        git -C "$project_path" worktree add "$wt_path" -b "$branch" 2>&1 \
          || die "git worktree add failed. If branch exists: git branch -D $branch"
      fi

      if [[ ! -e "$wt_path/deps" ]]; then
        local deps_source="$project_path/deps"
        [[ -d "$deps_source" ]] || die "deps not found at $deps_source — run mix deps.get first"
        ln -s ../../../deps "$wt_path/deps" \
          || echo "warning: could not symlink deps (may already exist)"
      fi

      echo "Verifying compile..."
      local clean_path
      clean_path=$(echo "$PATH" | tr ':' '\n' | grep -Ev '_build/prod/rel|/erts-' | tr '\n' ':' | sed 's/:$//')

      local output exit_code
      output=$(cd "$wt_path" && PATH="$clean_path" mix compile 2>&1) && exit_code=0 || exit_code=$?

      if [[ $exit_code -ne 0 ]]; then
        echo "Compile failed:"
        echo "$output" | tail -20
        die "Worktree setup failed — fix compile errors before proceeding"
      fi

      echo ""
      echo "Worktree ready:"
      echo "  Path:   $wt_path"
      echo "  Branch: $branch"
      echo ""
      echo "Usage:"
      echo "  cd $wt_path"
      echo "  export PATH=\$(echo \"\$PATH\" | tr ':' '\n' | grep -Ev '_build/prod/rel|/erts-' | tr '\n' ':' | sed 's/:\$//')"
      ;;

    remove)
      local branch="${1:-}"; need branch; shift || true
      local project_path="${EITS_PROJECT_PATH:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project-path) project_path="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done

      local wt_path="$project_path/.claude/worktrees/$branch"

      if [[ -L "$wt_path/deps" ]]; then
        unlink "$wt_path/deps" 2>/dev/null || true
      fi

      if [[ -d "$wt_path" ]]; then
        git -C "$project_path" worktree remove "$wt_path" --force 2>/dev/null || true
      fi

      git -C "$project_path" branch -D "$branch" 2>/dev/null || true

      echo "Removed: $branch"
      ;;

    *)
      echo "usage: eits worktree <create|remove>"
      echo ""
      echo "NOTE: scoped to EITS Elixir projects (.claude/worktrees/ layout, mix compile verification)"
      ;;
  esac
}

# ── me / whoami ───────────────────────────────────────────────────────────────

cmd_me() {
  local uuid="${EITS_SESSION_UUID:-}"
  echo "Session UUID:  ${EITS_SESSION_UUID:-(not set)}"
  echo "Session ID:    ${EITS_SESSION_ID:-(not set)}"
  echo "Agent UUID:    ${EITS_AGENT_UUID:-(not set)}"
  echo "Project ID:    ${EITS_PROJECT_ID:-(not set)}"
  echo "API URL:       ${BASE_URL}"
  if [[ -n "$uuid" ]]; then
    echo ""
    echo "Server-side session:"
    _get "/sessions/$uuid" 2>/dev/null || echo "(session not found on server)"
  fi
}

# ── help ──────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
eits — Eye in the Sky CLI
Base URL: ${BASE_URL}  (override: EITS_URL=<url>)

Commands:
  sessions      list|get|create|update|end|context
  tasks         list|get|create|update|done|begin|complete|annotate|start|claim|delete|link-session|unlink-session
                list --mine, update --title, begin --quiet
  notes         list|get|create|update|add
  projects      list|get|create
  agents        list|get|spawn
  commits       list|create
  jobs          list|get|create|update|run|delete
  dm            [--from <session_id|uuid>] --to <session_id|uuid> --message <text> [--response-required]
  channels      list|send|messages
  notifications create
  prompts       list|get
  teams         list|get|create|delete|members|join|status|update-member|leave|broadcast|my-teams
  timer         show|set|cancel   (default session: self / $EITS_SESSION_UUID)
  worktree      create|remove   (EITS Elixir projects only)
  me            Print current session/agent/project context and verify server-side

Env vars (injected by EITS hooks):
  EITS_SESSION_UUID  current session UUID (default --session / --from)
  EITS_AGENT_UUID    current agent UUID   (default --agent)
  EITS_PROJECT_ID    current project ID   (default --project)
  EITS_URL           API base URL         (default: http://localhost:5001/api/v1)

Requires: curl, jq
EOF
}

# ── dispatch ──────────────────────────────────────────────────────────────────

cmd="${1:-}"; shift || true
case "$cmd" in
  sessions)      cmd_sessions      "$@" ;;
  tasks)         cmd_tasks         "$@" ;;
  notes)         cmd_notes         "$@" ;;
  projects)      cmd_projects      "$@" ;;
  agents)        cmd_agents        "$@" ;;
  commits)       cmd_commits       "$@" ;;
  jobs)          cmd_jobs          "$@" ;;
  dm)            cmd_dm            "$@" ;;
  channels)      cmd_channels      "$@" ;;
  notifications) cmd_notifications "$@" ;;
  prompts)       cmd_prompts       "$@" ;;
  teams)         cmd_teams         "$@" ;;
  timer)         cmd_timer         "$@" ;;
  worktree)      cmd_worktree      "$@" ;;
  me|whoami)     cmd_me ;;
  help|--help|-h) usage ;;
  "") usage; exit 0 ;;
  *) die "unknown command: $cmd" ;;
esac
