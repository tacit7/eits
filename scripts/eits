#!/usr/bin/env bash
# eits - CLI for the Eye in the Sky REST API
# Base URL defaults to http://localhost:5001/api/v1
# Override with EITS_URL env var
#
# Session env vars (injected by EITS hooks):
#   EITS_SESSION_UUID  - current session UUID
#   EITS_AGENT_UUID    - current agent UUID (default for --agent)
#   EITS_PROJECT_ID    - current project ID  (default for --project)

set -euo pipefail

BASE_URL="${EITS_URL:-http://localhost:5001/api/v1}"
AUTH_ARGS=()
[[ -n "${EITS_API_KEY:-}" ]] && AUTH_ARGS=(-H "Authorization: Bearer ${EITS_API_KEY}")
# Any call with a session UUID is treated as orchestrator traffic for rate-limit bucketing.
# Phase 2 will switch to per-session bucketing; this header is the Phase 1 stopgap.
ROLE_ARGS=()
[[ -n "${EITS_SESSION_UUID:-}" ]] && ROLE_ARGS=(-H "x-eits-role: orchestrator")
# Phase 2: send the session UUID so the server can apply a per-session rate-limit bucket
# when the `rate_limit_per_session` setting is enabled. Falls through to the IP bucket
# when the flag is off, so this header is always safe to send.
SESSION_ARGS=()
[[ -n "${EITS_SESSION_UUID:-}" ]] && SESSION_ARGS=(-H "x-eits-session: ${EITS_SESSION_UUID}")

# Check deps
command -v curl &>/dev/null || { echo "error: curl is required" >&2; exit 1; }
command -v jq   &>/dev/null || { echo "error: jq is required" >&2; exit 1; }

# ── helpers ──────────────────────────────────────────────────────────────────

_backoff() {
  local _delay=$1
  local _jitter=$(( (RANDOM % 41) - 20 ))
  local _adjusted=$(( _delay + (_delay * _jitter / 100) ))
  [[ $_adjusted -lt 1 ]] && _adjusted=1
  echo $_adjusted
}

_curl() {
  local _body _status _attempt=0 _delay=2
  while [[ $_attempt -lt 4 ]]; do
    _body=$(curl -sk --write-out '\n%{http_code}' ${AUTH_ARGS[@]+"${AUTH_ARGS[@]}"} ${ROLE_ARGS[@]+"${ROLE_ARGS[@]}"} ${SESSION_ARGS[@]+"${SESSION_ARGS[@]}"} "$@")
    _status="${_body##*$'\n'}"
    _body="${_body%$'\n'*}"
    if [[ "$_status" == "429" ]]; then
      _attempt=$((_attempt + 1))
      if [[ $_attempt -lt 4 ]]; then
        local _sleep_time=$(_backoff "$_delay")
        echo "rate limited, retrying in ${_sleep_time}s..." >&2
        sleep "$_sleep_time"
        _delay=$((_delay * 2))
        [[ $_delay -gt 30 ]] && _delay=30
        continue
      fi
    fi
    break
  done
  if [[ "$_status" -ge 400 ]]; then
    # Normalize HTML error pages to a plain JSON error so agents don't get raw HTML
    local _display_body="$_body"
    if echo "$_body" | grep -qi '<!DOCTYPE\|<html'; then
      _display_body="{\"error\":\"server_error\",\"status\":$_status,\"hint\":\"server returned HTML — check server logs\"}"
    fi
    printf 'HTTP %s: %s\n' "$_status" "$_display_body" >&2
    return 1
  fi
  printf '%s\n' "$_body"
}

_get()    { _curl "$BASE_URL$1" | jq .; }
_post()   { _curl -X POST  -H "Content-Type: application/json" -d "$2" "$BASE_URL$1" | jq .; }
_patch()  { _curl -X PATCH -H "Content-Type: application/json" -d "$2" "$BASE_URL$1" | jq .; }
_delete() { _curl -X DELETE "$BASE_URL$1" | jq .; }

die()  { echo "error: $*" >&2; exit 1; }
need() { [[ -n "${!1:-}" ]] || die "$1 is required"; }

# Build a compact JSON object from key=value pairs, skipping empty values.
# Usage: json key1 val1 key2 val2 ...
json() {
  local args=("$@")
  local obj="{}"
  local i=0
  while [[ $i -lt ${#args[@]} ]]; do
    local k="${args[$i]}"
    local v="${args[$(($i+1))]}"
    i=$(($i+2))
    [[ -z "$v" ]] && continue
    if [[ "$k" == *_id && "$v" =~ ^[0-9]+$ ]]; then
      obj=$(jq -n --argjson base "$obj" --arg k "$k" --argjson v "$v" '$base + {($k): $v}')
    else
      obj=$(jq -n --argjson base "$obj" --arg k "$k" --arg v "$v" '$base + {($k): $v}')
    fi
  done
  echo "$obj"
}

# Auto-resolve project ID: env → CLAUDE_PROJECT_DIR path lookup → empty
_project_id() {
  if [ -n "${EITS_PROJECT_ID:-}" ]; then
    echo "$EITS_PROJECT_ID"
    return 0
  fi
  local dir="${CLAUDE_PROJECT_DIR:-$(pwd)}"
  # Strip worktree path if inside .claude/worktrees/<name>
  if [[ "$dir" == *"/.claude/worktrees/"* ]]; then
    dir="${dir%%/.claude/worktrees/*}"
  fi
  eits projects list --path "$dir" 2>/dev/null | jq -r '.projects[0]?.id // empty' | head -1
}

# ── display helpers ───────────────────────────────────────────────────────────

# Truncate string to n chars, appending … if over
_trunc() {
  local s="$1" n="$2"
  if [[ ${#s} -gt $n ]]; then printf '%s…' "${s:0:$((n-1))}"; else printf '%s' "$s"; fi
}

# Human-readable age from ISO8601 timestamp
_age() {
  local ts="${1:-}"
  [[ -z "$ts" || "$ts" == "null" ]] && echo "-" && return
  ts="${ts%%.*}"; ts="${ts%Z}"; ts="${ts/T/ }"
  local now; now=$(date +%s)
  local then
  then=$(date -j -f "%Y-%m-%d %H:%M:%S" "$ts" +%s 2>/dev/null) || \
  then=$(date -d "${ts}Z" +%s 2>/dev/null) || then="$now"
  local diff=$(( now - then ))
  if   [[ $diff -lt 60    ]]; then echo "${diff}s"
  elif [[ $diff -lt 3600  ]]; then echo "$(( diff / 60 ))m"
  elif [[ $diff -lt 86400 ]]; then echo "$(( diff / 3600 ))h"
  else echo "$(( diff / 86400 ))d"
  fi
}

# Table renderers — accept raw API JSON on stdin or as $1
_tbl_sessions() {
  local data="${1:-$(cat)}"
  local count; count=$(echo "$data" | jq '[.sessions[]?] | length')
  printf '%-10s  %-38s  %-6s  %s\n' "STATUS" "NAME" "ID" "AGE"
  printf '%-10s  %-38s  %-6s  %s\n' "----------" "--------------------------------------" "------" "---"
  echo "$data" | jq -r '.sessions[]? | [
    (.status // "-"),
    (.name // "(unnamed)"),
    ((.id) | tostring),
    (.last_activity_at // .created_at // "")
  ] | @tsv' | while IFS=$'\t' read -r status name id ts; do
    printf '%-10s  %-38s  %-6s  %s\n' \
      "$(_trunc "$status" 10)" \
      "$(_trunc "$name" 38)" \
      "$id" \
      "$(_age "$ts")"
  done
  [[ -n "$count" ]] && printf '\n%s session(s)\n' "$count"
}

_tbl_tasks() {
  local data="${1:-$(cat)}"
  local count; count=$(echo "$data" | jq '[.tasks[]?] | length')
  printf '%-14s  %-44s  %s\n' "STATE" "TITLE" "ID"
  printf '%-14s  %-44s  %s\n' "--------------" "--------------------------------------------" "------"
  echo "$data" | jq -r '.tasks[]? | [
    (.state // "-"),
    (.title // "(untitled)"),
    ((.id) | tostring)
  ] | @tsv' | while IFS=$'\t' read -r state title id; do
    printf '%-14s  %-44s  %s\n' \
      "$(_trunc "$state" 14)" \
      "$(_trunc "$title" 44)" \
      "$id"
  done
  [[ -n "$count" ]] && printf '\n%s task(s)\n' "$count"
}

_tbl_notes() {
  local data="${1:-$(cat)}"
  local count; count=$(echo "$data" | jq '[.notes[]?] | length')
  printf '%-2s  %-32s  %-40s  %s\n' "★" "TITLE" "PREVIEW" "ID"
  printf '%-2s  %-32s  %-40s  %s\n' "--" "--------------------------------" "----------------------------------------" "------"
  echo "$data" | jq -r '.notes[]? | [
    (if .starred then "★" else " " end),
    (.title // "(untitled)"),
    ((.body // "") | gsub("\n";" ") | .[0:40]),
    ((.id) | tostring)
  ] | @tsv' | while IFS=$'\t' read -r star title preview id; do
    printf '%-2s  %-32s  %-40s  %s\n' \
      "$star" \
      "$(_trunc "$title" 32)" \
      "$(_trunc "$preview" 40)" \
      "$id"
  done
  [[ -n "$count" ]] && printf '\n%s note(s)\n' "$count"
}

_tbl_commits() {
  local data="${1:-$(cat)}"
  local count; count=$(echo "$data" | jq '[.commits[]?] | length')
  printf '%-10s  %-52s  %s\n' "HASH" "MESSAGE" "AGE"
  printf '%-10s  %-52s  %s\n' "----------" "----------------------------------------------------" "---"
  echo "$data" | jq -r '.commits[]? | [
    ((.commit_hash // "") | .[0:9]),
    (.commit_message // "(no message)"),
    (.inserted_at // "")
  ] | @tsv' | while IFS=$'\t' read -r hash msg ts; do
    printf '%-10s  %-52s  %s\n' \
      "$hash" \
      "$(_trunc "$msg" 52)" \
      "$(_age "$ts")"
  done
  [[ -n "$count" ]] && printf '\n%s commit(s)\n' "$count"
}

# ── sessions ──────────────────────────────────────────────────────────────────

cmd_sessions() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits sessions <list|get|create|update|end|complete|waiting|archive|unarchive|context|tasks|notes>"; echo "  list --search <q>   full-text search sessions by name/description"; return 0; }
  case "$sub" in
    list)
      # eits sessions list [--search <q>] [--name <partial>] [--status <s>] [--project <id>] [--agent <uuid>] [--limit <n>] [--mine] [--include-archived] [--with-tasks]
      # --agent is mutually exclusive with --search, --status, --project, and --mine
      # --mine is mutually exclusive with --agent, --search, --status, and --project
      # --name cannot combine with --agent or --mine
      local qs="" _agent_flag=0 _other_flag=0 _mine_flag=0 _json=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --search)     [[ $_agent_flag -eq 1 || $_mine_flag -eq 1 ]] && die "--search cannot combine with --agent or --mine"; _other_flag=1; qs="${qs}&q=$(printf '%s' "$2" | jq -Rr @uri)"; shift 2 ;;
          --name)       [[ $_agent_flag -eq 1 || $_mine_flag -eq 1 ]] && die "--name cannot combine with --agent or --mine"; _other_flag=1; qs="${qs}&name=$(printf '%s' "$2" | jq -Rr @uri)"; shift 2 ;;
          --status)     [[ $_agent_flag -eq 1 || $_mine_flag -eq 1 ]] && die "--status cannot combine with --agent or --mine"; _other_flag=1; qs="${qs}&status=$2";     shift 2 ;;
          --project)    [[ $_agent_flag -eq 1 || $_mine_flag -eq 1 ]] && die "--project cannot combine with --agent or --mine"; _other_flag=1; qs="${qs}&project_id=$2"; shift 2 ;;
          --agent)      [[ $_other_flag -eq 1 || $_mine_flag -eq 1 ]] && die "--agent is mutually exclusive with --search, --status, --project, and --mine"; _agent_flag=1; qs="${qs}&agent_id=$2"; shift 2 ;;
          --mine)       [[ $_agent_flag -eq 1 || $_other_flag -eq 1 ]] && die "--mine cannot combine with --agent, --search, --status, and --project"; _mine_flag=1; local _mine="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"; [[ -n "$_mine" ]] || die "--mine requires EITS_SESSION_UUID or EITS_SESSION_ID to be set"; qs="${qs}&session_id=$_mine"; shift ;;
          --limit)      qs="${qs}&limit=$2";      shift 2 ;;
          --include-archived) qs="${qs}&include_archived=true"; shift ;;
          --with-tasks) qs="${qs}&with_tasks=true"; shift ;;
          --json)       _json=1; shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      local _resp; _resp=$(_curl "$BASE_URL/sessions?${qs#&}")
      if [[ $_json -eq 1 ]]; then echo "$_resp" | jq .; else _tbl_sessions "$_resp"; fi
      ;;
    tasks)
      # eits sessions tasks <uuid>
      local uuid="${1:-}"; need uuid
      _curl "$BASE_URL/tasks?session_id=$uuid" | jq .
      ;;
    notes)
      # eits sessions notes <uuid> [<note_id>] [--full] [--starred] [--add <body>] [--title <t>]
      # Default: preview listing (id, title, first 100 chars, size, date)
      # With note_id: show full body of that note
      # --full: dump full body for all notes
      # --starred: only starred notes
      # --add "body": create a new note on this session
      local uuid="${1:-}"; need uuid; shift || true
      local full=0 starred="" note_id="" add_body="" add_title=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --full)    full=1;          shift ;;
          --starred) starred="&starred=true"; shift ;;
          --add)     add_body="$2";  shift 2 ;;
          --title)   add_title="$2"; shift 2 ;;
          -*)        die "unknown flag: $1" ;;
          *)         note_id="$1";   shift ;;
        esac
      done
      # --add: create a new note
      if [[ -n "$add_body" ]]; then
        _post "/notes" "$(json parent_type "session" parent_id "$uuid" body "$add_body" title "$add_title")" | jq '{id, title, message: "Note created"}'
        return 0
      fi
      # Specific note by ID
      if [[ -n "$note_id" ]]; then
        _get "/notes/$note_id"
        return 0
      fi
      # Listing
      local _notes_resp
      _notes_resp=$(_curl "$BASE_URL/notes?session_id=$uuid${starred}" 2>/dev/null) || { echo "no notes found" >&2; return 0; }
      local _count
      _count=$(echo "$_notes_resp" | jq '.results | length')
      if [[ "${_count:-0}" -eq 0 ]]; then
        echo "no notes for this session"
        return 0
      fi
      if [[ $full -eq 1 ]]; then
        echo "$_notes_resp" | jq .
      else
        echo "$_notes_resp" | jq -r '
          .results[] |
          ( .body // "" | .[0:100] | gsub("\n"; " ") ) as $preview |
          ( if (.body_length // (.body | length)) > 100 then "…" else "" end ) as $ellipsis |
          ( .created_at // "" | if . != "" then (.[5:10] | gsub("-";"/")) else "?" end ) as $date |
          ( if .starred then "★ " else "  " end ) as $star |
          "[" + (.id | tostring) + "] " + $star + (.title // "(untitled)") + "  (" + $date + ")  " + $preview + $ellipsis
        '
        echo ""
        echo "  ${_count} note(s) — use --full to dump bodies, or pass <note_id> to read one"
      fi
      ;;
    get)
      local uuid="${1:-}"; need uuid
      [[ "$uuid" == "self" ]] && { uuid="${EITS_SESSION_UUID:-}"; [[ -n "$uuid" ]] || die "EITS_SESSION_UUID is not set"; }
      local _sess_resp
      _sess_resp=$(_curl "$BASE_URL/sessions/$uuid") || return 1
      # Augment with note count so agents know notes exist without a separate query
      local _note_count
      _note_count=$(_curl "$BASE_URL/notes?session_id=$uuid&limit=1" 2>/dev/null \
        | jq -r '.results | length' 2>/dev/null || echo "0")
      echo "$_sess_resp" | jq --argjson nc "${_note_count:-0}" \
        '. + {note_count: $nc, _hint: (if $nc > 0 then ("has \($nc) note(s) — run: eits sessions notes " + (.uuid // .id | tostring)) else null end)}'
      ;;
    create)
      # eits sessions create --session-id <uuid> [--name <n>] [--description <d>] [--project <p>] [--project-path <path>] [--model <m>] [--entrypoint <e>]
      local session_id="" name="" description="" project_name="" project_path="" model="" entrypoint=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --session-id)  session_id="$2";   shift 2 ;;
          --name)        name="$2";         shift 2 ;;
          --description) description="$2";  shift 2 ;;
          --project)     project_name="$2"; shift 2 ;;
          --project-path) project_path="$2"; shift 2 ;;
          --model)       model="$2";        shift 2 ;;
          --entrypoint)  entrypoint="$2";   shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need session_id
      _post "/sessions" "$(json session_id "$session_id" name "$name" description "$description" project_name "$project_name" project_path "$project_path" model "$model" entrypoint "$entrypoint")"
      ;;
    update)
      # eits sessions update <uuid> [--status <status>] [--reason <reason>] [--intent <text>] [--entrypoint <e>] [--name <name>] [--description <desc>] [--clear-entrypoint] [--ended-at <ISO8601>] [--project-id <id>]
      local uuid="${1:-}"; need uuid; shift
      [[ "$uuid" == "self" ]] && { uuid="${EITS_SESSION_UUID:-}"; [[ -n "$uuid" ]] || die "EITS_SESSION_UUID is not set"; }
      local status="" reason="" intent="" entrypoint="" name="" description="" clear_entrypoint="" ended_at="" project_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --status)      status="$2";      shift 2 ;;
          --reason)      reason="$2";      shift 2 ;;
          --intent)      intent="$2";      shift 2 ;;
          --entrypoint)  entrypoint="$2";  shift 2 ;;
          --name)        name="$2";        shift 2 ;;
          --description) description="$2"; shift 2 ;;
          --project-id)  project_id="$2";  shift 2 ;;
          --clear-entrypoint) clear_entrypoint="true"; shift ;;
          --ended-at)    ended_at="$2";    shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _patch "/sessions/$uuid" "$(json status "$status" status_reason "$reason" intent "$intent" entrypoint "$entrypoint" name "$name" description "$description" clear_entrypoint "$clear_entrypoint" ended_at "$ended_at" project_id "$project_id")"
      ;;
    end)
      # eits sessions end <uuid> [--final-status <completed|failed|waiting>]
      local uuid="${1:-}"; need uuid; shift
      local final_status=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --final-status) final_status="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      if [[ -n "$final_status" ]]; then
        _post "/sessions/$uuid/end" "$(json final_status "$final_status")"
      else
        _post "/sessions/$uuid/end" '{}'
      fi
      ;;
    complete)
      # eits sessions complete [<uuid>]  -- defaults to EITS_SESSION_UUID
      local uuid="${1:-${EITS_SESSION_UUID:-}}"
      [[ -n "$uuid" ]] || die "session UUID required (pass as argument or set EITS_SESSION_UUID)"
      _post "/sessions/$uuid/complete" '{}'
      ;;
    waiting)
      # eits sessions waiting [<uuid>]  -- defaults to EITS_SESSION_UUID
      local uuid="${1:-${EITS_SESSION_UUID:-}}"
      [[ -n "$uuid" ]] || die "session UUID required (pass as argument or set EITS_SESSION_UUID)"
      _post "/sessions/$uuid/waiting" '{}'
      ;;
    archive)
      # eits sessions archive <uuid>
      local uuid="${1:-}"; need uuid
      _post "/sessions/$uuid/archive" '{}'
      ;;
    unarchive)
      # eits sessions unarchive <uuid>
      local uuid="${1:-}"; need uuid
      _post "/sessions/$uuid/unarchive" '{}'
      ;;
    context)
      # eits sessions context <uuid>                                    (GET)
      # eits sessions context <uuid> --text <text> [--metadata <json>]  (PATCH)
      # eits sessions context <uuid> --from-stdin [--metadata <json>]   (PATCH; body from stdin)
      local uuid="${1:-}"; need uuid; shift || true
      local text="" from_stdin=0 metadata=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --text)       text="$2"; shift 2 ;;
          --from-stdin) from_stdin=1; shift ;;
          --metadata)   metadata="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      if [[ $from_stdin -eq 1 ]]; then
        text="$(cat)"
      fi
      if [[ -n "$text" ]]; then
        if [[ -n "$metadata" ]]; then
          _patch "/sessions/$uuid/context" "$(jq -n --arg c "$text" --argjson m "$metadata" '{context: $c, metadata: $m}')"
        else
          _patch "/sessions/$uuid/context" "$(jq -n --arg c "$text" '{context: $c}')"
        fi
      else
        _get "/sessions/$uuid/context"
      fi
      ;;
    *)
      echo "usage: eits sessions <list|get|create|update|end|complete|waiting|archive|unarchive|context|tasks|notes>"; echo "  list --search <q>   full-text search sessions by name/description"
      ;;
  esac
}

# ── tasks ─────────────────────────────────────────────────────────────────────

cmd_tasks() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { cat <<'TASKS_HELP'
usage: eits tasks <subcommand> [options]

Subcommands:
  list      [-s <session>] [-p <project>] [-l <limit>] [--mine] [--all]
  get       <id>
  begin     -t <title> [-p <project>] [-d <desc>] [-q]   create + claim in one shot
  complete  <id> -m <message>                             atomic annotate + done
  annotate  <id> -b <body> [-t <title>]
  update    <id> -s <state> [-t <title>] [-d <desc>]
  search    <query> [--project <id>] [--state <id>]
  states    show state IDs, names, and accepted aliases
  create    --title <t> [--project <id>] [--description <d>]
  claim     <id>
  delete    <id>
  bulk-update --ids <id,...> --state <id|name>

  When EITS_SESSION_UUID is set, 'list' scopes to the current session.
  Pass --all to list across all sessions.

Run 'eits tasks states' to see state IDs and all accepted name aliases.
TASKS_HELP
  return 0; }
  case "$sub" in
    list)
      # eits tasks list [--project <id>] [--session <uuid>] [--agent <uuid>] [--q <query>] [--search <query>] [--state <id>] [--state-name <name>] [--limit <n>] [--mine|--assigned] [--created-by] [--all]
      # Agent-centric default: when EITS_SESSION_UUID/EITS_SESSION_ID is set, shows only the
      # current session's tasks. Pass --all to list across all sessions.
      # --mine/--assigned: tasks where current session is the active executor (linked via task_sessions)
      # --created-by: tasks created by the current session (via created_by_session_id)
      local qs="" _session_flag=0 _mine_flag=0 _all_flag=0 _agent_flag=0 _json=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project|-p) qs="${qs}&project_id=$2"; shift 2 ;;
          --session|-s) [[ $_mine_flag -eq 1 ]] && die "--mine/--assigned and --session are mutually exclusive"; _session_flag=1; qs="${qs}&session_id=$2"; shift 2 ;;
          --agent)   _agent_flag=1; qs="${qs}&agent_id=$2"; shift 2 ;;
          --q|--search|-q) qs="${qs}&q=$(printf '%s' "$2" | jq -Rr @uri)"; shift 2 ;;
          --state)
            # Positional remap: 1=todo(1), 2=progress(2), 3=review(4), 4=done(3)
            local _list_sid
            case "$2" in
              1) _list_sid=1 ;; 2) _list_sid=2 ;; 3) _list_sid=4 ;; 4) _list_sid=3 ;;
              *) _list_sid="$2" ;;
            esac
            qs="${qs}&state_id=$_list_sid"; shift 2 ;;
          --state-name)
            case "$2" in
              todo)              qs="${qs}&state_id=1"; shift 2 ;;
              in-progress|start) qs="${qs}&state_id=2"; shift 2 ;;
              done|complete)     qs="${qs}&state_id=3"; shift 2 ;;
              in-review|review)  qs="${qs}&state_id=4"; shift 2 ;;
              *) die "unknown state name: $2" ;;
            esac ;;
          --limit|-l) qs="${qs}&limit=$2";      shift 2 ;;
          --mine|--assigned) [[ $_session_flag -eq 1 ]] && die "--mine/--assigned and --session are mutually exclusive"; _mine_flag=1; local _mine="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"; [[ -n "$_mine" ]] || die "--mine/--assigned requires EITS_SESSION_UUID or EITS_SESSION_ID to be set"; qs="${qs}&session_id=$_mine"; shift ;;
          --created-by) local _creator="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"; [[ -n "$_creator" ]] || die "--created-by requires EITS_SESSION_UUID or EITS_SESSION_ID to be set"; qs="${qs}&created_by_session_id=$_creator"; shift ;;
          --all)     _all_flag=1; shift ;;
          --json)    _json=1; shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      # Agent-centric default: when running as an agent, scope to current session
      # unless --all, --session, --mine, or --agent explicitly overrides the scope
      if [[ $_all_flag -eq 0 && $_session_flag -eq 0 && $_mine_flag -eq 0 && $_agent_flag -eq 0 ]]; then
        local _self="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"
        [[ -n "$_self" ]] && qs="${qs}&session_id=$_self"
      fi
      local _resp; _resp=$(_curl "$BASE_URL/tasks?${qs#&}")
      if [[ $_json -eq 1 ]]; then echo "$_resp" | jq .; else _tbl_tasks "$_resp"; fi
      ;;
    get)
      local id="${1:-}"; need id
      _get "/tasks/$id"
      ;;
    create)
      # eits tasks create --title <t> [--description <d>] [--project <id>] [--priority <p>] [--session <uuid>] [--agent <uuid>] [--tags <id1,id2,...>] [--team <id>] [--due-at <ISO8601>]
      # Defaults: --agent from $EITS_AGENT_UUID, --project from $EITS_PROJECT_ID, --session from $EITS_SESSION_UUID (falls back to $EITS_SESSION_ID)
      local title="" description="" project_id="${EITS_PROJECT_ID:-}" priority="" session_id="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}" agent_id="${EITS_AGENT_UUID:-}" tags="" team_id="" due_at=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --title)       title="$2";       shift 2 ;;
          --description) description="$2"; shift 2 ;;
          --project)     project_id="$2";  shift 2 ;;
          --priority)    priority="$2";    shift 2 ;;
          --session)     session_id="$2";  shift 2 ;;
          --agent)       agent_id="$2";    shift 2 ;;
          --tags)        tags="$2";        shift 2 ;;
          --team)        team_id="$2";     shift 2 ;;
          --due-at)      due_at="$2";      shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need title
      local body
      body="$(json title "$title" description "$description" project_id "$project_id" priority "$priority" session_id "$session_id" agent_id "$agent_id" team_id "$team_id" due_at "$due_at")"
      if [[ -n "$tags" ]]; then
        local tag_array
        tag_array=$(echo "$tags" | jq -R 'split(",") | map(tonumber)')
        body=$(echo "$body" | jq --argjson ids "$tag_array" '. + {tag_ids: $ids}')
      fi
      _post "/tasks" "$body"
      ;;
    update)
      # eits tasks update <id> [--state <id|name>] [--priority <p>] [--description <d>] [--title <t>] [--due-at <ISO8601>]
      # State IDs:   1=To Do, 2=In Progress, 3=Done, 4=In Review
      # State names: todo, start|in-progress|progress, done, review|in-review
      # Prefer: eits tasks complete <id> --message "..." (sets Done + annotates in one shot)
      local id="${1:-}"; need id; shift
      local updates="{}"
      # Normalize a --state value: numeric → state_id, name → server alias string
      _resolve_state() {
        local v="$1"
        if [[ "$v" =~ ^[0-9]+$ ]]; then
          # Map positional 1-4 to actual DB state IDs.
          # Workflow order: 1=To Do, 2=In Progress, 3=In Review, 4=Done
          # DB IDs:         1       2               4             3
          local _sid
          case "$v" in
            1) _sid=1 ;;
            2) _sid=2 ;;
            3) _sid=4 ;;
            4) _sid=3 ;;
            *) _sid="$v" ;;
          esac
          updates=$(echo "$updates" | jq --argjson n "$_sid" '. + {state_id: $n}')
        else
          # Map friendly names to server aliases (tr for bash 3.2 compat — no ${v,,})
          local _vl; _vl="$(echo "$v" | tr '[:upper:]' '[:lower:]')"
          case "$_vl" in
            todo|"to do"|"to-do")                      v="todo" ;;
            "in progress"|in-progress|progress|start)  v="start" ;;
            done|complete|completed)                   v="done" ;;
            "in review"|in-review|review)              v="in-review" ;;
          esac
          updates=$(echo "$updates" | jq --arg s "$v" '. + {state: $s}')
        fi
      }
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --state|-s|--state-name) _resolve_state "$2"; shift 2 ;;
          --priority)    updates=$(echo "$updates" | jq --arg v "$2" '. + {priority: $v}');    shift 2 ;;
          --description|-d) updates=$(echo "$updates" | jq --arg v "$2" '. + {description: $v}'); shift 2 ;;
          --title|-t)    updates=$(echo "$updates" | jq --arg v "$2" '. + {title: $v}');       shift 2 ;;
          --due-at)      updates=$(echo "$updates" | jq --arg v "$2" '. + {due_at: $v}');      shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _patch "/tasks/$id" "${updates}"
      ;;
    done)
      echo "Warning: eits tasks done is deprecated. Use eits tasks complete instead." >&2
      local id="${1:-}"; need id
      _patch "/tasks/$id" '{"state":"done"}'
      ;;
    claim)
      local id="${1:-}"; need id
      local _sess="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"
      # POST /tasks/:id/claim transfers session ownership atomically:
      # removes all existing task_sessions links, adds claimer's session, transitions to In Progress
      _curl -X POST -H "Content-Type: application/json" \
        -d "$(json session_id "$_sess")" \
        "$BASE_URL/tasks/$id/claim" | jq .
      ;;
    start)
      echo "Warning: eits tasks start is deprecated. Use eits tasks claim instead." >&2
      local id="${1:-}"; need id
      local _sess="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"
      _patch "/tasks/$id" "$(json state "start" session_id "$_sess")"
      if [[ -n "$_sess" ]]; then
        _curl -sf -X POST -H "Content-Type: application/json" \
          -d "$(json session_id "$_sess")" \
          "$BASE_URL/tasks/$id/sessions" >/dev/null 2>&1 || true
      fi
      ;;
    delete)
      local id="${1:-}"; need id
      _delete "/tasks/$id"
      ;;
    annotate)
      # eits tasks annotate <id> --body <text> [--title <t>]
      # Retries on 429 with exponential backoff (2s, 4s, 8s). On persistent failure,
      # writes to ~/.eits/pending-annotations.log for drain on next session startup.
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "usage: eits tasks annotate <id> --body <text> [--title <title>]"; return 0; }
      local id="${1:-}"; need id; shift
      local body="" title=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --body|-b)  body="$2";  shift 2 ;;
          --title|-t) title="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need body
      local _ann_payload; _ann_payload="$(json body "$body" title "$title")"
      local _ann_attempt=0 _ann_delay=2 _ann_ok=0
      while [[ $_ann_attempt -le 3 ]]; do
        local _ann_body _ann_status
        _ann_body=$(curl -sk --write-out '\n%{http_code}' -X POST \
          -H "Content-Type: application/json" \
          ${AUTH_ARGS[@]+"${AUTH_ARGS[@]}"} ${ROLE_ARGS[@]+"${ROLE_ARGS[@]}"} ${SESSION_ARGS[@]+"${SESSION_ARGS[@]}"} \
          -d "$_ann_payload" \
          "$BASE_URL/tasks/$id/annotations")
        _ann_status="${_ann_body##*$'\n'}"
        _ann_body="${_ann_body%$'\n'*}"
        if [[ "$_ann_status" == "429" && $_ann_attempt -lt 3 ]]; then
          local _sleep_time=$(_backoff "$_ann_delay")
          echo "annotate rate limited, retrying in ${_sleep_time}s..." >&2
          sleep "$_sleep_time"
          _ann_delay=$((_ann_delay * 2))
          [[ $_ann_delay -gt 30 ]] && _ann_delay=30
          _ann_attempt=$((_ann_attempt + 1))
          continue
        fi
        if [[ "$_ann_status" -lt 400 ]]; then
          printf '%s\n' "$_ann_body" | jq .
          _ann_ok=1
        fi
        break
      done
      if [[ $_ann_ok -eq 0 ]]; then
        local _pending_dir="${HOME}/.eits"
        mkdir -p "$_pending_dir"
        printf '%s\n' "$(printf '{"task_id":%s,"body":%s,"title":%s}' \
          "$(printf '%s' "$id" | jq -Rs .)" \
          "$(printf '%s' "$body" | jq -Rs .)" \
          "$(printf '%s' "$title" | jq -Rs .)")" \
          >> "${_pending_dir}/pending-annotations.log"
        echo "annotate failed after retries — queued to ~/.eits/pending-annotations.log" >&2
        return 1
      fi
      ;;
    link-session)
      # eits tasks link-session <task_id> [<session_uuid>]
      # session_uuid defaults to $EITS_SESSION_UUID (falls back to $EITS_SESSION_ID) if not provided
      local id="${1:-}"; need id; shift
      local session_id="${1:-${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}}"
      [[ -n "$session_id" ]] || die "session_uuid is required (or set EITS_SESSION_UUID / EITS_SESSION_ID)"
      _post "/tasks/$id/sessions" "$(json session_id "$session_id")"
      ;;
    unlink-session)
      local id="${1:-}"; need id; shift
      local session_id="${1:-}"; need session_id
      _delete "/tasks/$id/sessions/$session_id"
      ;;
    complete)
      # eits tasks complete <id> [<message>] [--message <text>]
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "usage: eits tasks complete <id> <message>  OR  eits tasks complete <id> --message <text>"; return 0; }
      local id="${1:-}"; need id; shift
      local message=""
      # Check if next arg is not a flag and treat it as the message
      if [[ $# -gt 0 && "$1" != --* ]]; then
        message="$1"
        shift
      fi
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --message|-m) message="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need message
      # Guard: bail early if the task is already Done (state_id 3) to prevent double-close noise
      local _check_body
      _check_body=$(_curl "$BASE_URL/tasks/$id" 2>/dev/null) || true
      if [[ -n "$_check_body" ]]; then
        local _current_state
        _current_state=$(echo "$_check_body" | jq -r '.task.state_id // .state_id // empty' 2>/dev/null)
        if [[ "$_current_state" == "3" ]]; then
          echo '{"status":"already_closed","message":"task is already Done — no change made","task_id":'"$id"'}' | jq .
          return 0
        fi
      fi
      local _sess_id="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"
      local _comp_payload; _comp_payload="$(json message "$message" session_id "$_sess_id")"
      local _comp_attempt=0 _comp_delay=2 _comp_ok=0
      while [[ $_comp_attempt -le 3 ]]; do
        local _comp_body _comp_status
        _comp_body=$(curl -sk --write-out '\n%{http_code}' -X POST \
          -H "Content-Type: application/json" \
          ${AUTH_ARGS[@]+"${AUTH_ARGS[@]}"} ${ROLE_ARGS[@]+"${ROLE_ARGS[@]}"} ${SESSION_ARGS[@]+"${SESSION_ARGS[@]}"} \
          -d "$_comp_payload" \
          "$BASE_URL/tasks/$id/complete")
        _comp_status="${_comp_body##*$'\n'}"
        _comp_body="${_comp_body%$'\n'*}"
        if [[ "$_comp_status" == "429" && $_comp_attempt -lt 3 ]]; then
          local _sleep_time=$(_backoff "$_comp_delay")
          echo "complete rate limited, retrying in ${_sleep_time}s..." >&2
          sleep "$_sleep_time"
          _comp_delay=$((_comp_delay * 2))
          [[ $_comp_delay -gt 30 ]] && _comp_delay=30
          _comp_attempt=$((_comp_attempt + 1))
          continue
        fi
        if [[ "$_comp_status" -lt 400 ]]; then
          printf '%s\n' "$_comp_body" | jq .
          _comp_ok=1
        else
          printf 'HTTP %s: %s\n' "$_comp_status" "$_comp_body" >&2
        fi
        break
      done
      [[ $_comp_ok -eq 1 ]] || { echo "complete failed after retries — task $id may need manual completion" >&2; return 1; }
      ;;
    begin|quick)
      # eits tasks begin [--id <task_id>] [--title <t>] [--description <d>] [--project <id>] [--priority <p>] [--quiet|-q]
      # With --id: claims an existing task (links session + sets In Progress). No new task created.
      # Without --id: creates a new task then claims it.
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && {
        cat <<'HELP'
usage: eits tasks begin [--id <task_id>] --title <title> [options]

  --id <task_id>     Claim a pre-existing task instead of creating a new one.
                     Links the current session and sets state to In Progress atomically.
                     When --id is given, --title and --description are ignored.

  --title <text>     Task title (required when --id is not given)
  --description <t>  Task description
  --project <id>     Project ID (default: $EITS_PROJECT_ID)
  --priority <p>     Priority
  --quiet|-q         Print only the task ID

NOTES:
  Orchestrators that pre-create tasks and pass Task ID: <n> in agent instructions
  should tell agents to run: eits tasks begin --id <n>
  This atomically claims the task without creating a duplicate.
HELP
        return 0; }
      local task_id_flag="" title="" description="" project_id="${EITS_PROJECT_ID:-}" priority="" quiet=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --id)             task_id_flag="$2"; shift 2 ;;
          --title|-t)       title="$2";        shift 2 ;;
          --description|-d) description="$2";  shift 2 ;;
          --project|-p)     project_id="$2";   shift 2 ;;
          --priority)       priority="$2";     shift 2 ;;
          --quiet|-q)       quiet=1;           shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      local _sess="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"

      # --id path: claim existing task, skip create
      if [[ -n "$task_id_flag" ]]; then
        local _claim_resp
        _claim_resp=$(_curl -X POST -H "Content-Type: application/json" \
          -d "$(json session_id "$_sess")" \
          "$BASE_URL/tasks/$task_id_flag/claim")
        if [[ $quiet -eq 0 ]]; then
          echo "$_claim_resp" | jq .
        else
          echo "$task_id_flag"
        fi
        return 0
      fi

      # create path: require --title
      need title
      if [[ -n "$_sess" ]]; then
        local _enc_title
        _enc_title=$(printf '%s' "$title" | jq -Rr @uri)
        local _dup_count
        _dup_count=$(_curl "$BASE_URL/tasks?session_id=$_sess&q=$_enc_title" 2>/dev/null \
          | jq -r --arg t "$title" '([.tasks[]? | select(.title == $t)] | length)' 2>/dev/null || echo "0")
        if [[ "${_dup_count:-0}" -gt 0 ]]; then
          echo "warning: task '$title' already exists for this session — refusing to create duplicate" >&2
          exit 1
        fi
      fi
      local body
      body="$(json title "$title" description "$description" project_id "$project_id" priority "$priority" session_id "$_sess")"
      local create_resp task_id
      create_resp=$(_post "/tasks" "$body")
      task_id=$(echo "$create_resp" | jq -r '.task_id // empty')
      [[ -n "$task_id" ]] || die "task creation failed"
      _patch "/tasks/$task_id" "$(json state "start" session_id "$_sess")" > /dev/null
      if [[ -n "$_sess" ]]; then
        _curl -sf -X POST -H "Content-Type: application/json" \
          -d "$(json session_id "$_sess")" \
          "$BASE_URL/tasks/$task_id/sessions" >/dev/null 2>&1 || true
      fi
      if [[ $quiet -eq 0 ]]; then
        # Fetch full task so response includes state name, title, etc.
        _curl "$BASE_URL/tasks/$task_id" | jq '{task_id: .task.id, title: .task.title, state: .task.state, state_id: .task.state_id, message: "Task created"}'
      else
        echo "$task_id"
      fi
      ;;
    search)
      # eits tasks search <query> [--project <id>] [--limit <n>] [--state <id>]
      local query="${1:-}"; [[ -n "$query" ]] || die "query is required"
      shift
      local qs="q=$(printf '%s' "$query" | jq -Rr @uri)"
      local project_id="${EITS_PROJECT_ID:-}"
      local limit="" state_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project)  project_id="$2"; shift 2 ;;
          --limit)    limit="$2";      shift 2 ;;
          --state)    state_id="$2";   shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      [[ -n "$project_id" ]] && qs="${qs}&project_id=$project_id"
      [[ -n "$limit" ]]      && qs="${qs}&limit=$limit"
      [[ -n "$state_id" ]]   && qs="${qs}&state_id=$state_id"
      _get "/tasks?${qs}"
      ;;
    sessions)
      # eits tasks sessions <id> — list sessions linked to a task
      local id="${1:-}"; need id
      _get "/tasks/$id/sessions"
      ;;
    tag)
      # eits tasks tag <task_id> <tag_id>
      local task_id="${1:-}"; need task_id; shift
      local tag_id="${1:-}"; need tag_id
      _post "/tasks/$task_id/tags" "$(json tag_id "$tag_id")"
      ;;
    states)
      printf '%-4s %-14s %-30s %s\n' "Pos" "Name" "Accepted aliases" "Notes"
      printf '%-4s %-14s %-30s %s\n' 1 "To Do"       "todo, to-do, to do"           ""
      printf '%-4s %-14s %-30s %s\n' 2 "In Progress" "start, in-progress, progress" "(set by tasks begin / tasks claim)"
      printf '%-4s %-14s %-30s %s\n' 3 "In Review"   "review, in-review"            ""
      printf '%-4s %-14s %-30s %s\n' 4 "Done"        "done, complete, completed"    "(set by tasks complete)"
      printf '\nPositional numbers 1-4 and named aliases both work with --state:\n'
      printf '  eits tasks update <id> --state 4      # done\n'
      printf '  eits tasks update <id> --state done   # same\n'
      printf '  eits tasks update <id> -s done        # shorthand\n'
      ;;
    bulk-update)
      # eits tasks bulk-update --ids <id,id,...> [--state <id|name>] [--priority <p>] [--title <t>]
      # Applies the same update to all specified task IDs.
      # Example: eits tasks bulk-update --ids 101,102,103 --state 3
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && {
        cat <<'HELP'
usage: eits tasks bulk-update --ids <id,...> [--state <id>] [--priority <p>] [--title <t>]

Apply the same field update to multiple tasks at once.

  --ids <id,...>     Comma-separated task IDs (required)
  --state <id>       Workflow state: 1=To Do, 2=In Progress, 3=Done, 4=In Review
  --priority <p>     Priority value
  --title <t>        New title (applied to all — use with care)

Examples:
  eits tasks bulk-update --ids 101,102,103 --state 3
  eits tasks bulk-update --ids 200,201 --state 1 --priority high
HELP
        return 0; }
      local ids_raw="" updates="{}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --ids)
            ids_raw="$2"; shift 2 ;;
          --state)
            if [[ "$2" =~ ^[0-9]+$ ]]; then
              updates=$(echo "$updates" | jq --argjson v "$2" '. + {state_id: $v}')
            else
              updates=$(echo "$updates" | jq --arg v "$2" '. + {state: $v}')
            fi
            shift 2 ;;
          --priority)    updates=$(echo "$updates" | jq --arg v "$2" '. + {priority: $v}');    shift 2 ;;
          --title)       updates=$(echo "$updates" | jq --arg v "$2" '. + {title: $v}');       shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      [[ -n "$ids_raw" ]] || die "--ids is required"
      [[ "$updates" != "{}" ]] || die "at least one field to update is required (--state, --priority, --title)"
      local ok=0 fail=0
      IFS=',' read -ra _ids <<< "$ids_raw"
      for _id in "${_ids[@]}"; do
        _id="${_id// /}"  # trim spaces
        [[ -z "$_id" ]] && continue
        if _curl -X PATCH -H "Content-Type: application/json" -d "$updates" "$BASE_URL/tasks/$_id" >/dev/null 2>&1; then
          printf 'updated #%s\n' "$_id"
          ok=$(( ok + 1 ))
        else
          printf 'failed  #%s\n' "$_id" >&2
          fail=$(( fail + 1 ))
        fi
      done
      printf '%d updated, %d failed\n' "$ok" "$fail"
      [[ "$fail" -eq 0 ]]
      ;;
    *)
      echo "usage: eits tasks <list|get|create|update|bulk-update|done|begin|start|claim|complete|delete|annotate|link-session|unlink-session|search|sessions|tag|states> [--mine|--assigned] [--created-by] [--title] [--quiet]"
      ;;
  esac
}

# ── notes ─────────────────────────────────────────────────────────────────────

cmd_notes() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && {
    cat <<'HELP'
usage: eits notes <list|search|get|create|update|add>

  list   [--session <uuid>] [--task <id>] [--project <id>] [--mine]
         [--starred] [--q <query>] [--limit <n>] [--full]
         Default: preview listing (title + 100 char snippet). --full dumps bodies.

  search <query> [--project <id>] [--starred] [--limit <n>] [--full]

  get    <id>                     Show full note body

  add    --body <text> [--title <t>] [--starred]
         Create a note on the current session (requires EITS_SESSION_UUID)

  create --parent-type <session|task|agent|project> --parent-id <id>
         --body <text> [--title <t>] [--starred]

  update <id> [--body <text>] [--title <t>] [--starred]
HELP
    return 0; }

  # Shared preview renderer — expects JSON with .results[]
  _notes_preview() {
    local resp="$1" full="${2:-0}"
    local count
    count=$(echo "$resp" | jq '.results | length')
    if [[ "${count:-0}" -eq 0 ]]; then
      echo "no notes found"
      return 0
    fi
    if [[ "$full" -eq 1 ]]; then
      echo "$resp" | jq .
    else
      echo "$resp" | jq -r '
        .results[] |
        ( .body // "" | .[0:100] | gsub("\n"; " ") ) as $preview |
        ( if (.body_length // (.body // "" | length)) > 100 then "…" else "" end ) as $ellipsis |
        ( .created_at // "" | if . != "" then (.[5:10] | gsub("-";"/")) else "?" end ) as $date |
        ( if .starred then "★ " else "  " end ) as $star |
        ( (.body_length // (.body // "" | length) | tostring) + " B" ) as $size |
        "[" + (.id | tostring) + "] " + $star + (.title // "(untitled)") + "  (" + $date + ", " + $size + ")  " + $preview + $ellipsis
      '
      echo ""
      echo "  ${count} note(s) — pass <note_id> to read one, --full to dump bodies"
    fi
  }

  case "$sub" in
    list)
      # eits notes list [--session <uuid>] [--task <id>] [--project <id>] [--mine] [--all]
      #                 [--starred] [--q <query>] [--limit <n>] [--full]
      # Agent-centric default: when EITS_SESSION_UUID is set, shows only the current
      # session's notes. Pass --all to list across all sessions.
      local qs="" full=0 _session_flag=0 _mine_flag=0 _all_flag=0 _task_flag=0 _json=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --q|--search) qs="${qs}&q=$(printf '%s' "$2" | jq -Rr @uri)"; shift 2 ;;
          --session)    [[ $_mine_flag -eq 1 ]] && die "--session and --mine are mutually exclusive"
                        _session_flag=1; qs="${qs}&session_id=$2"; shift 2 ;;
          --task)       _task_flag=1; qs="${qs}&task_id=$2"; shift 2 ;;
          --project)    qs="${qs}&project_id=$2"; shift 2 ;;
          --mine)       [[ $_session_flag -eq 1 ]] && die "--mine and --session are mutually exclusive"
                        _mine_flag=1
                        local _mine="${EITS_SESSION_UUID:-}"; [[ -n "$_mine" ]] || die "--mine requires EITS_SESSION_UUID to be set"
                        qs="${qs}&session_id=$_mine"; shift ;;
          --all)        _all_flag=1; shift ;;
          --starred)    qs="${qs}&starred=true"; shift ;;
          --limit)      qs="${qs}&limit=$2"; shift 2 ;;
          --full)       full=1; shift ;;
          --json)       _json=1; shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      # Agent-centric default: scope to current session unless overridden
      if [[ $_all_flag -eq 0 && $_session_flag -eq 0 && $_mine_flag -eq 0 && $_task_flag -eq 0 ]]; then
        local _self="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"
        [[ -n "$_self" ]] && qs="${qs}&session_id=$_self"
      fi
      local _notes_resp; _notes_resp=$(_curl "$BASE_URL/notes?${qs#&}")
      if [[ $_json -eq 1 ]]; then echo "$_notes_resp" | jq .
      elif [[ $full -eq 1 ]]; then _notes_preview "$_notes_resp" "$full"
      else _tbl_notes "$_notes_resp"; fi
      ;;
    get)
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "usage: eits notes get <id>"; return 0; }
      local id="${1:-}"; need id
      _get "/notes/$id"
      ;;
    create)
      # eits notes create --parent-type <session|task|agent> --parent-id <id> --body <text> [--title <t>] [--starred]
      local parent_type="" parent_id="" body="" title="" starred="0"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --parent-type) parent_type="$2"; shift 2 ;;
          --parent-id)   parent_id="$2";   shift 2 ;;
          --body)        body="$2";        shift 2 ;;
          --title)       title="$2";       shift 2 ;;
          --starred)     starred="1";      shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need parent_type; need parent_id; need body
      _post "/notes" "$(json parent_type "$parent_type" parent_id "$parent_id" body "$body" title "$title" starred "$starred")"
      ;;
    update)
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "usage: eits notes update <id> [--body <text>] [--title <t>] [--starred] [--parent-type <session|task|agent|project>] [--parent-id <id>]"; return 0; }
      local id="${1:-}"; need id; shift
      local updates="{}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --body)        updates=$(echo "$updates" | jq --arg v "$2" '. + {body: $v}');        shift 2 ;;
          --title)       updates=$(echo "$updates" | jq --arg v "$2" '. + {title: $v}');       shift 2 ;;
          --starred)     updates=$(echo "$updates" | jq '. + {starred: true}');                shift ;;
          --unstar)      updates=$(echo "$updates" | jq '. + {starred: false}');               shift ;;
          --parent-type) updates=$(echo "$updates" | jq --arg v "$2" '. + {parent_type: $v}'); shift 2 ;;
          --parent-id)   updates=$(echo "$updates" | jq --arg v "$2" '. + {parent_id: $v}');   shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _patch "/notes/$id" "${updates}"
      ;;
    search)
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "usage: eits notes search <query> [--project <id>] [--starred] [--limit <n>] [--full]"; return 0; }
      local query="${1:-}"; need query; shift
      local qs="q=$(printf '%s' "$query" | jq -Rr @uri)" full=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) qs="${qs}&project_id=$2"; shift 2 ;;
          --starred) qs="${qs}&starred=true";  shift ;;
          --limit)   qs="${qs}&limit=$2";      shift 2 ;;
          --full)    full=1;                   shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _notes_preview "$(_curl "$BASE_URL/notes?${qs}")" "$full"
      ;;
    add)
      # eits notes add --body <text> [--title <t>] [--starred]
      # Creates a note attached to the current session
      local body="" title="" starred="0"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --body)    body="$2";   shift 2 ;;
          --title)   title="$2";  shift 2 ;;
          --starred) starred="1"; shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need body
      local parent_id="${EITS_SESSION_UUID:-}"; [[ -n "$parent_id" ]] || die "EITS_SESSION_UUID is not set"
      _post "/notes" "$(json parent_type "session" parent_id "$parent_id" body "$body" title "$title" starred "$starred")"
      ;;
    *)
      echo "usage: eits notes <list|search|get|create|update|add>"
      ;;
  esac
}

# ── projects ──────────────────────────────────────────────────────────────────

cmd_projects() {
  local sub="${1:-}"; shift || true
  [[ "${sub:-}" == "--help" || "${sub:-}" == "-h" ]] && { echo "usage: eits projects <list|get|create>"; return 0; }
  case "$sub" in
    list)
      local qs=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --path) qs="${qs}&path=$(printf '%s' "$2" | jq -Rr @uri)"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/projects?${qs#&}" | jq .
      ;;
    get)
      local id="${1:-}"; need id
      _get "/projects/$id"
      ;;
    create)
      # eits projects create --name <n> --path <p> [--slug <s>] [--remote <url>] [--git-remote <url>] [--repo-url <url>] [--branch <b>] [--active|--inactive]
      local name="" path="" slug="" remote_url="" git_remote="" repo_url="" branch="" active=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)       name="$2";       shift 2 ;;
          --path)       path="$2";       shift 2 ;;
          --slug)       slug="$2";       shift 2 ;;
          --remote)     remote_url="$2"; shift 2 ;;
          --git-remote) git_remote="$2"; shift 2 ;;
          --repo-url)   repo_url="$2";   shift 2 ;;
          --branch)     branch="$2";     shift 2 ;;
          --active)     active="true";   shift ;;
          --inactive)   active="false";  shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need name; need path
      _post "/projects" "$(json name "$name" path "$path" slug "$slug" remote_url "$remote_url" git_remote "$git_remote" repo_url "$repo_url" branch "$branch" active "$active")"
      ;;
    *)
      echo "usage: eits projects <list|get|create>"
      ;;
  esac
}

# ── agents ────────────────────────────────────────────────────────────────────

cmd_agents() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits agents <list|get|spawn>"; return 0; }
  case "$sub" in
    list)
      # eits agents list [--project <id>] [--status <status>] [--limit <n>]
      local qs=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) qs="${qs}&project_id=$2"; shift 2 ;;
          --status)  qs="${qs}&status=$2";     shift 2 ;;
          --limit)   qs="${qs}&limit=$2";      shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/agents?${qs#&}" | jq .
      ;;
    get)
      local id="${1:-}"; need id
      _get "/agents/$id"
      ;;
    spawn)
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { cat <<'USAGE'
usage: eits agents spawn --instructions <text> [options]

Required (one of):
  --instructions <text>        Agent instructions (inline)
  --instructions-file <path>   Read instructions from file (mutually exclusive with --instructions)

Options:
  --interpolate-env            Substitute $VAR and ${VAR} in instructions using current environment
  --model <m>                  Model name (default: server default)
  --provider <p>               Provider (default: claude)
  --project-id <n>             Project ID (default: $EITS_PROJECT_ID)
  --project-path <path>        Project path (default: current dir)
  --worktree <branch>          Git worktree branch to create for the agent
  --stash-if-dirty             Auto-stash uncommitted changes before worktree create
  --effort-level <level>       Effort level hint
  --parent-session-id <n>      Parent session integer ID (links spawned session)
  --parent-agent-id <n>        Parent agent ID
  --team-name <name>           Join this team on spawn (by name)
  --team-id <id>               Join this team on spawn (by integer ID; resolved to name)
  --member-name <alias>        Team member display name
  --agent <name>               Agent definition name
  --name <n>                   Session name
  --yolo                       Bypass sandbox restrictions
  --dry-run                    Validate inputs without hitting spawn endpoint; print the curl command

Valid models (--provider claude, default):
  claude-opus-4-7, claude-opus-4-6, claude-sonnet-4-6, claude-sonnet-4-5-20250929,
  claude-haiku-4-5-20251001, opus, opus[1m], sonnet, sonnet[1m], haiku

Valid models (--provider codex):
  gpt-5.4, gpt-5.2-codex, gpt-5.1-codex-max, gpt-5.4-mini, gpt-5.3-codex, gpt-5.2

Valid models (--provider gemini):
  gemini-2.5-pro, gemini-2.5-flash, gemini-2.5-flash-lite

NOTES:
  - --worktree requires a clean git tree. If the working directory has uncommitted
    changes, spawn will fail. Use --stash-if-dirty to auto-stash before the worktree
    is created, or commit your changes first.
  - --provider and --model are validated locally before hitting the API. Passing an
    invalid combo exits immediately with a clear error message.
  - Provider/model pairs are not cross-compatible. --provider codex --model sonnet
    is invalid; use --model gpt-5.4 for Codex.
  - $EITS_PROJECT_ID is used as the default --project-id. In spawned agents it must
    be set explicitly in the instructions string — it is not injected as an OS env var
    for Claude sessions (Codex injects it via cli.ex automatically).

Examples:
  eits agents spawn --instructions "Review PR #42" --parent-session-id $EITS_SESSION_ID
  eits agents spawn --instructions-file /tmp/agent.txt --worktree fix/my-bug --stash-if-dirty
  eits agents spawn --instructions "Fix bug" --worktree fix/my-bug --team-name "audit"
  eits agents spawn --instructions "Fix bug" --team-id 5
  eits agents spawn --instructions-file /tmp/agent.txt --interpolate-env
  eits agents spawn --instructions "Deploy" --team-name test --dry-run
USAGE
        return 0; }
      local instructions="" instructions_set=0 instructions_file="" interpolate_env="false" model="" provider="" project_id="${EITS_PROJECT_ID:-}" project_path="${PWD:-}"
      local worktree="" stash_if_dirty="false" effort_level="" parent_session_id="" parent_agent_id=""
      local team_name="" team_id="" member_name="" agent_name="" session_name="" bypass_sandbox="false" dry_run="false"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --instructions)      instructions="$2"; instructions_set=1; shift 2 ;;
          --instructions-file) instructions_file="$2";  shift 2 ;;
          --interpolate-env)   interpolate_env="true";  shift ;;
          --model)             model="$2";              shift 2 ;;
          --provider)          provider="$2";           shift 2 ;;
          --project-id)        project_id="$2";         shift 2 ;;
          --project-path)      project_path="$2";       shift 2 ;;
          --worktree)          worktree="$2";           shift 2 ;;
          --stash-if-dirty)    stash_if_dirty="true";   shift ;;
          --effort-level)      effort_level="$2";       shift 2 ;;
          --parent-session-id) parent_session_id="$2";  shift 2 ;;
          --parent-agent-id)   parent_agent_id="$2";    shift 2 ;;
          --team-name)         team_name="$2";          shift 2 ;;
          --team-id)           team_id="$2";            shift 2 ;;
          --member-name)       member_name="$2";        shift 2 ;;
          --agent)             agent_name="$2";         shift 2 ;;
          --name)              session_name="$2";       shift 2 ;;
          --yolo)              bypass_sandbox="true";   shift ;;
          --dry-run)           dry_run="true";          shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      # Mutual exclusion: --instructions and --instructions-file cannot both be set
      [[ $instructions_set -eq 1 && -n "$instructions_file" ]] && die "--instructions and --instructions-file are mutually exclusive"

      # Validate provider/model combos locally before hitting the API
      if [[ -n "$provider" || -n "$model" ]]; then
        local _eff_provider="${provider:-claude}"
        case "$_eff_provider" in
          claude)
            if [[ -n "$model" ]]; then
              case "$model" in
                claude-opus-4-7|claude-opus-4-6|claude-sonnet-4-6|claude-sonnet-4-5-20250929|claude-haiku-4-5-20251001|opus|"opus[1m]"|sonnet|"sonnet[1m]"|haiku) ;;
                *) die "invalid model '$model' for provider 'claude'. Valid: claude-opus-4-7, claude-opus-4-6, claude-sonnet-4-6, claude-sonnet-4-5-20250929, claude-haiku-4-5-20251001, opus, opus[1m], sonnet, sonnet[1m], haiku" ;;
              esac
            fi ;;
          codex)
            if [[ -n "$model" ]]; then
              case "$model" in
                gpt-5.4|gpt-5.2-codex|gpt-5.1-codex-max|gpt-5.4-mini|gpt-5.3-codex|gpt-5.2) ;;
                *) die "invalid model '$model' for provider 'codex'. Valid: gpt-5.4, gpt-5.2-codex, gpt-5.1-codex-max, gpt-5.4-mini, gpt-5.3-codex, gpt-5.2" ;;
              esac
            fi ;;
          gemini)
            if [[ -n "$model" ]]; then
              case "$model" in
                gemini-2.5-pro|gemini-2.5-flash|gemini-2.5-flash-lite) ;;
                *) die "invalid model '$model' for provider 'gemini'. Valid: gemini-2.5-pro, gemini-2.5-flash, gemini-2.5-flash-lite" ;;
              esac
            fi ;;
          *) die "unknown provider '$provider'. Valid: claude, codex, gemini" ;;
        esac
      fi
      # Load from file if provided
      if [[ -n "$instructions_file" ]]; then
        [[ -f "$instructions_file" ]] || die "--instructions-file: file not found: $instructions_file"
        [[ -r "$instructions_file" ]] || die "--instructions-file: file not readable: $instructions_file"
        instructions="$(cat "$instructions_file")"
      fi
      need instructions

      # Resolve --team-id to team name (mutually exclusive with --team-name)
      if [[ -n "$team_id" && -n "$team_name" ]]; then
        die "--team-id and --team-name are mutually exclusive"
      fi
      if [[ -n "$team_id" ]]; then
        local _team_info
        _team_info=$(_curl "$BASE_URL/teams/$team_id" 2>/dev/null || true)
        team_name=$(echo "$_team_info" | jq -r '.name // empty' 2>/dev/null || true)
        [[ -n "$team_name" ]] || die "--team-id $team_id: team not found"
      fi

      # Dry-run validations
      if [[ "$dry_run" == "true" ]]; then
        # Validate team exists if team_name is provided
        if [[ -n "$team_name" ]]; then
          local teams_list
          teams_list=$(_curl "$BASE_URL/teams" 2>&1 || true)
          if echo "$teams_list" | grep -q "HTTP"; then
            die "--dry-run: Failed to fetch teams: $(echo "$teams_list" | grep "HTTP")"
          fi
          if ! echo "$teams_list" | jq -e ".teams | map(.name) | contains([\"$team_name\"])" >/dev/null 2>&1; then
            die "--dry-run: Team not found: $team_name"
          fi
        fi

        # Validate parent session exists if provided
        if [[ -n "$parent_session_id" ]]; then
          local session_check
          session_check=$(_curl "$BASE_URL/sessions/$parent_session_id" 2>&1 || true)
          if echo "$session_check" | grep -q "HTTP"; then
            die "--dry-run: Failed to fetch session: $(echo "$session_check" | grep "HTTP")"
          fi
          if ! echo "$session_check" | jq -e ".id" >/dev/null 2>&1; then
            die "--dry-run: Parent session not found: $parent_session_id"
          fi
        fi
      fi
      # Interpolate environment variables if requested
      if [[ "$interpolate_env" == "true" ]]; then
        if command -v envsubst &>/dev/null; then
          instructions=$(printf '%s\n' "$instructions" | envsubst)
        elif command -v perl &>/dev/null; then
          instructions=$(printf '%s' "$instructions" | perl -pe 's/\$\{([A-Za-z_][A-Za-z0-9_]*)\}|\$([A-Za-z_][A-Za-z0-9_]*)/my $k=$1//$2; defined $ENV{$k} ? $ENV{$k} : ""/ge')
        else
          die "--interpolate-env requires envsubst (gettext) or perl"
        fi
      fi
      local payload
      payload=$(jq -n \
        --arg     instructions      "$instructions" \
        --arg     model             "$model" \
        --arg     provider          "$provider" \
        --arg     project_path      "$project_path" \
        --arg     worktree          "$worktree" \
        --arg     effort_level      "$effort_level" \
        --arg     team_name         "$team_name" \
        --arg     member_name       "$member_name" \
        --arg     agent             "$agent_name" \
        --arg     name              "$session_name" \
        --argjson project_id        "${project_id:-null}" \
        --argjson parent_session_id "${parent_session_id:-null}" \
        --argjson parent_agent_id   "${parent_agent_id:-null}" \
        --argjson bypass_sandbox    "$bypass_sandbox" \
        --argjson stash_if_dirty    "$stash_if_dirty" \
        '{instructions: $instructions}
         + (if $model             != "" then {model: $model}                           else {} end)
         + (if $provider          != "" then {provider: $provider}                     else {} end)
         + (if $project_path      != "" then {project_path: $project_path}             else {} end)
         + (if $worktree          != "" then {worktree: $worktree}                     else {} end)
         + (if $effort_level      != "" then {effort_level: $effort_level}             else {} end)
         + (if $team_name         != "" then {team_name: $team_name}                   else {} end)
         + (if $member_name       != "" then {member_name: $member_name}               else {} end)
         + (if $agent             != "" then {agent: $agent}                           else {} end)
         + (if $name              != "" then {name: $name}                             else {} end)
         + (if $project_id        != null then {project_id: $project_id}               else {} end)
         + (if $parent_session_id != null then {parent_session_id: $parent_session_id} else {} end)
         + (if $parent_agent_id   != null then {parent_agent_id: $parent_agent_id}     else {} end)
         + (if $bypass_sandbox           then {bypass_sandbox: true}                   else {} end)
         + (if $stash_if_dirty           then {stash_if_dirty: true}                   else {} end)')
      # Dry-run: print the curl command and exit without making the request
      if [[ "$dry_run" == "true" ]]; then
        echo "Dry-run validation passed. Curl command that would execute:"
        echo ""
        echo "curl -sk -X POST \\"
        echo "  -H 'Content-Type: application/json' \\"
        if [[ -n "${EITS_API_KEY:-}" ]]; then
          echo "  -H 'Authorization: Bearer <EITS_API_KEY>' \\"
        fi
        echo "  -d '$payload' \\"
        echo "  '$BASE_URL/agents'"
        echo ""
        echo "Request payload:"
        echo "$payload" | jq .
        return 0
      fi

      local spawn_log="${EITS_SPAWN_LOG:-$HOME/.eits/spawn-errors.log}"
      local _sp_attempt=0 _sp_delay=2 _sp_ok=0
      local _sp_body _sp_status _sp_resp_body
      while [[ $_sp_attempt -le 3 ]]; do
        _sp_body=$(curl -sk --write-out '\n%{http_code}' -X POST \
          -H "Content-Type: application/json" \
          ${AUTH_ARGS[@]+"${AUTH_ARGS[@]}"} ${ROLE_ARGS[@]+"${ROLE_ARGS[@]}"} ${SESSION_ARGS[@]+"${SESSION_ARGS[@]}"} \
          -d "$payload" \
          "$BASE_URL/agents")
        _sp_status="${_sp_body##*$'\n'}"
        _sp_resp_body="${_sp_body%$'\n'*}"
        if [[ "$_sp_status" == "429" && $_sp_attempt -lt 3 ]]; then
          local _sleep_time=$(_backoff "$_sp_delay")
          echo "spawn rate limited, retrying in ${_sleep_time}s..." >&2
          sleep "$_sleep_time"
          _sp_delay=$((_sp_delay * 2))
          [[ $_sp_delay -gt 30 ]] && _sp_delay=30
          _sp_attempt=$((_sp_attempt + 1))
          continue
        fi
        if [[ "$_sp_status" -lt 400 ]]; then
          _sp_ok=1
        fi
        break
      done
      if [[ $_sp_ok -eq 0 ]]; then
        local _ts; _ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
        mkdir -p "$(dirname "$spawn_log")"
        printf '%s rc=%s cmd=agents/spawn %s\n' "$_ts" "$_sp_status" "$_sp_resp_body" >> "$spawn_log"
        printf 'spawn failed (HTTP %s): %s\n' "$_sp_status" "$_sp_resp_body" >&2
        return 1
      fi
      printf '%s\n' "$_sp_resp_body" | jq .
      ;;
    *)
      echo "usage: eits agents <list|get|spawn>"
      ;;
  esac
}

# ── commits ───────────────────────────────────────────────────────────────────

cmd_commits() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits commits <list|create>"; return 0; }
  case "$sub" in
    list)
      # eits commits list [--session <uuid>] [--agent <uuid>] [--mine] [--all] [--limit <n>]
      # Agent-centric default: when EITS_SESSION_UUID/EITS_SESSION_ID is set, shows only
      # current session's commits. Pass --all to list across all sessions.
      # --mine, --session, and --agent are mutually exclusive
      # eits commits list [--session <uuid>] [--agent <uuid>] [--mine] [--all] [--since <hash>] [--limit <n>]
      # --since <hash>: return only commits newer than the given hash (sprint reconciliation)
      local qs="" _session_flag=0 _mine_flag=0 _agent_flag=0 _all_flag=0 _json=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --session) [[ $_mine_flag -eq 1 || $_agent_flag -eq 1 ]] && die "--session is mutually exclusive with --mine and --agent"; _session_flag=1; qs="${qs}&session_id=$2"; shift 2 ;;
          --agent)   [[ $_mine_flag -eq 1 || $_session_flag -eq 1 ]] && die "--agent is mutually exclusive with --mine and --session"; _agent_flag=1; qs="${qs}&agent_id=$2"; shift 2 ;;
          --mine)    [[ $_session_flag -eq 1 || $_agent_flag -eq 1 ]] && die "--mine is mutually exclusive with --session and --agent"; _mine_flag=1; local _mine="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"; [[ -n "$_mine" ]] || die "--mine requires EITS_SESSION_UUID or EITS_SESSION_ID"; qs="${qs}&session_id=$_mine"; shift ;;
          --all)     _all_flag=1; shift ;;
          --since)   qs="${qs}&since_hash=$(printf '%s' "$2" | jq -Rr @uri)"; shift 2 ;;
          --limit)   qs="${qs}&limit=$2"; shift 2 ;;
          --json)    _json=1; shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      # Agent-centric default: scope to current session unless overridden
      if [[ $_all_flag -eq 0 && $_session_flag -eq 0 && $_mine_flag -eq 0 && $_agent_flag -eq 0 ]]; then
        local _self="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"
        [[ -n "$_self" ]] && qs="${qs}&session_id=$_self"
      fi
      local _resp; _resp=$(_curl "$BASE_URL/commits?${qs#&}")
      if [[ $_json -eq 1 ]]; then echo "$_resp" | jq .; else _tbl_commits "$_resp"; fi
      ;;
    create)
      # eits commits create [--agent <uuid>] --hash <h1> [--hash <h2>] [--message <m>] [--quiet|-q]
      # --agent defaults to $EITS_AGENT_UUID; falls back to session lookup when unset
      # --quiet: print only the commit hash(es) — one per line; nothing on duplicate
      local agent_id="${EITS_AGENT_UUID:-}" hashes=() messages=() quiet=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --agent)     agent_id="$2";  shift 2 ;;
          --hash)      hashes+=("$2"); shift 2 ;;
          --message)   messages+=("$2"); shift 2 ;;
          --quiet|-q)  quiet=1;        shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      if [[ -z "$agent_id" && -n "${EITS_SESSION_UUID:-}" ]]; then
        agent_id=$(_curl "$BASE_URL/sessions/${EITS_SESSION_UUID}" 2>/dev/null | jq -r '.agent_id // empty' 2>/dev/null || true)
      fi
      [[ -n "$agent_id" ]] || die "agent_id is required (or set EITS_AGENT_UUID)"
      if [[ ${#hashes[@]} -eq 0 ]]; then
        local auto_hash
        auto_hash=$(git rev-parse HEAD 2>/dev/null) || die "not in a git repo; use --hash"
        hashes=("$auto_hash")
        if [[ ${#messages[@]} -eq 0 ]]; then
          local auto_msg
          auto_msg=$(git log -1 --format=%s 2>/dev/null || echo "")
          [[ -n "$auto_msg" ]] && messages=("$auto_msg")
        fi
      fi
      local hashes_json; hashes_json=$(printf '%s\n' "${hashes[@]}" | jq -R . | jq -s .)
      local payload
      if [[ ${#messages[@]} -gt 0 ]]; then
        local msgs_json; msgs_json=$(printf '%s\n' "${messages[@]}" | jq -R . | jq -s .)
        payload=$(jq -n --arg a "$agent_id" --argjson h "$hashes_json" --argjson m "$msgs_json" \
          '{agent_id: $a, commit_hashes: $h, commit_messages: $m}')
      else
        payload=$(jq -n --arg a "$agent_id" --argjson h "$hashes_json" \
          '{agent_id: $a, commit_hashes: $h}')
      fi
      local _commit_resp
      _commit_resp=$(_post "/commits" "$payload")
      if [[ $quiet -eq 1 ]]; then
        # Print only the hashes of newly created commits — nothing for duplicates
        echo "$_commit_resp" | jq -r '.commits[]?.commit_hash // empty'
      else
        echo "$_commit_resp" | jq .
      fi
      ;;
    *)
      echo "usage: eits commits <list|create>"
      ;;
  esac
}

# ── jobs ──────────────────────────────────────────────────────────────────────

cmd_jobs() {
  local sub="${1:-}"; shift || true
  [[ "${sub:-}" == "--help" || "${sub:-}" == "-h" ]] && { echo "usage: eits jobs <list|get|create|update|run|delete>"; return 0; }
  case "$sub" in
    list)
      # eits jobs list [--project <id>] [--global]
      local qs=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) qs="${qs}&project_id=$2"; shift 2 ;;
          --global)  qs="${qs}&global=true";   shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/jobs?${qs#&}" | jq .
      ;;
    get)
      local id="${1:-}"; need id
      _get "/jobs/$id"
      ;;
    create)
      # eits jobs create --name <n> --job-type <type> --schedule-type <type> --schedule-value <val> [--description <d>] [--config <json>] [--enabled] [--project <id>]
      local name="" description="" job_type="" schedule_type="" schedule_value="" config="" enabled="" project_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)           name="$2";           shift 2 ;;
          --description)    description="$2";    shift 2 ;;
          --job-type)       job_type="$2";       shift 2 ;;
          --schedule-type)  schedule_type="$2";  shift 2 ;;
          --schedule-value) schedule_value="$2"; shift 2 ;;
          --config)         config="$2";         shift 2 ;;
          --enabled)        enabled="true";      shift ;;
          --project)        project_id="$2";     shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need name
      need job_type
      need schedule_type
      need schedule_value
      local body
      body="$(json name "$name" description "$description" job_type "$job_type" schedule_type "$schedule_type" schedule_value "$schedule_value" enabled "$enabled" project_id "$project_id")"
      if [[ -n "$config" ]]; then
        body=$(echo "$body" | jq --argjson c "$config" '. + {config: $c}')
      fi
      _post "/jobs" "$body"
      ;;
    update)
      # eits jobs update <id> [--name <n>] [--description <d>] [--job-type <type>] [--schedule-type <type>] [--schedule-value <val>] [--config <json>] [--enabled|--disabled] [--project <id>]
      local id="${1:-}"; need id; shift
      local updates="{}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)           updates=$(echo "$updates" | jq --arg v "$2" '. + {name: $v}');            shift 2 ;;
          --description)    updates=$(echo "$updates" | jq --arg v "$2" '. + {description: $v}');    shift 2 ;;
          --job-type)       updates=$(echo "$updates" | jq --arg v "$2" '. + {job_type: $v}');       shift 2 ;;
          --schedule-type)  updates=$(echo "$updates" | jq --arg v "$2" '. + {schedule_type: $v}');  shift 2 ;;
          --schedule-value) updates=$(echo "$updates" | jq --arg v "$2" '. + {schedule_value: $v}'); shift 2 ;;
          --config)         updates=$(echo "$updates" | jq --argjson v "$2" '. + {config: $v}');     shift 2 ;;
          --enabled)        updates=$(echo "$updates" | jq '. + {enabled: true}');                   shift ;;
          --disabled)       updates=$(echo "$updates" | jq '. + {enabled: false}');                  shift ;;
          --project)        updates=$(echo "$updates" | jq --arg v "$2" '. + {project_id: $v}');     shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _patch "/jobs/$id" "$updates"
      ;;
    run)
      local id="${1:-}"; need id
      _post "/jobs/$id/run" '{}'
      ;;
    delete)
      local id="${1:-}"; need id
      _delete "/jobs/$id"
      ;;
    *)
      echo "usage: eits jobs <list|get|create|update|run|delete>"
      ;;
  esac
}

# ── dm ────────────────────────────────────────────────────────────────────────

cmd_dm() {
  # eits dm list [--session <uuid|id>] [--from <uuid|id>] [--limit <n>]
  if [[ "${1:-}" == "list" || "${1:-}" == "--list" ]]; then
    shift || true
    local session="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}" limit=20 from=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --session|-s) session="$2"; shift 2 ;;
        --from|-f)    from="$2";    shift 2 ;;
        --limit|-n)   limit="$2";   shift 2 ;;
        *) die "unknown flag: $1" ;;
      esac
    done
    need session
    local qs="session=${session}&limit=${limit}"
    [[ -n "$from" ]] && qs="${qs}&from=${from}"
    _get "/dm?${qs}"
    return
  fi

  # eits dm [--from <session_id|uuid>] --to <session_id|uuid> --message <text> [--response-required]
  # --from defaults to $EITS_SESSION_UUID or $EITS_SESSION_ID when omitted
  local from="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}" to="" message="" response_required="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from)              from="$2";              shift 2 ;;
      --to)                to="$2";                shift 2 ;;
      --message|-m)        message="$2";           shift 2 ;;
      --response-required) response_required="true"; shift ;;
      *) die "unknown flag: $1" ;;
    esac
  done
  need from; need to; need message

  local payload
  payload=$(jq -n --arg f "$from" --arg t "$to" --arg m "$message" --argjson r "$response_required" \
    '{from_session_id: $f, to_session_id: $t, message: $m, response_required: $r}')
  _post "/dm" "$payload"
}

# ── timer ─────────────────────────────────────────────────────────────────────

cmd_timer() {
  local sub="${1:-}"; shift || true
  [[ "${sub:-}" == "--help" || "${sub:-}" == "-h" ]] && { echo "usage: eits timer <show|set|cancel> [<session_id>] [options]"; return 0; }
  case "$sub" in
    show|get)
      local session="self"
      if [[ $# -gt 0 && "$1" != --* ]]; then session="$1"; shift; fi
      [[ "$session" == "self" ]] && session="${EITS_SESSION_UUID:-}"
      need session
      _get "/sessions/$session/timer"
      ;;
    set|schedule)
      local session="self"
      if [[ $# -gt 0 && "$1" != --* ]]; then session="$1"; shift; fi
      [[ "$session" == "self" ]] && session="${EITS_SESSION_UUID:-}"
      need session
      local preset="" delay_ms="" mode="" message=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --preset)     preset="$2";    shift 2 ;;
          --delay-ms|--delay) delay_ms="$2"; shift 2 ;;
          --mode)       mode="$2";      shift 2 ;;
          --message|-m) message="$2";   shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      [[ -n "$preset" || -n "$delay_ms" ]] || die "--preset or --delay-ms is required"
      local body="{}"
      [[ -n "$preset" ]]   && body=$(echo "$body" | jq --arg v "$preset"   '. + {preset: $v}')
      [[ -n "$delay_ms" ]] && body=$(echo "$body" | jq --argjson v "$delay_ms" '. + {delay_ms: $v}')
      [[ -n "$mode" ]]     && body=$(echo "$body" | jq --arg v "$mode"     '. + {mode: $v}')
      [[ -n "$message" ]]  && body=$(echo "$body" | jq --arg v "$message"  '. + {message: $v}')
      _post "/sessions/$session/timer" "$body"
      ;;
    cancel)
      local session="self"
      if [[ $# -gt 0 && "$1" != --* ]]; then session="$1"; shift; fi
      [[ "$session" == "self" ]] && session="${EITS_SESSION_UUID:-}"
      need session
      _delete "/sessions/$session/timer"
      ;;
    *)
      cat <<USAGE
usage: eits timer <show|set|cancel> [<session_id>] [options]

session_id defaults to self (\$EITS_SESSION_UUID) when omitted.

Subcommands:
  show   [<session_id>]                                Show active timer (404 if none)
  set    [<session_id>] --preset <5m|10m|15m|30m|1h>  Schedule one-shot timer
  set    [<session_id>] --delay-ms <N> [--mode once|repeating] [--message <text>]
  cancel [<session_id>]                                Cancel active timer

Examples:
  eits timer set --preset 15m            # wake self up in 15 min
  eits timer set --preset 30m --mode repeating
  eits timer set 1234 --delay-ms 300000 --message "check in"
  eits timer show
  eits timer cancel
USAGE
      ;;
  esac
}

# ── channels ──────────────────────────────────────────────────────────────────

cmd_channels() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits channels <create|list|send|messages|join|leave>"; return 0; }
  case "$sub" in
    create)
      # eits channels create --name <name> [--project <id>] [--description <text>] [--type <public|private>]
      local name="" project_id="" description="" channel_type="public" session_id="${EITS_SESSION_UUID:-}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)        name="$2";         shift 2 ;;
          --project)     project_id="$2";   shift 2 ;;
          --description) description="$2";  shift 2 ;;
          --type)        channel_type="$2"; shift 2 ;;
          --session)     session_id="$2";   shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need name
      local payload
      payload="$(json name "$name" channel_type "$channel_type" session_id "$session_id")"
      [[ -n "$project_id"   ]] && payload="$(echo "$payload" | jq --arg v "$project_id"   '. + {project_id: ($v | tonumber)}')"
      [[ -n "$description"  ]] && payload="$(echo "$payload" | jq --arg v "$description"  '. + {description: $v}')"
      _post "/channels" "$payload"
      ;;
    list)
      local project_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) project_id="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      if [[ -n "$project_id" ]]; then
        _curl "$BASE_URL/channels?project_id=$project_id" | jq .
      else
        _get "/channels"
      fi
      ;;
    send)
      # eits channels send <channel_id> --body <text> [--session <uuid>] [--broadcast-team <team_id>]
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "usage: eits channels send <channel_id> --body <text> [--session <uuid|id>] [--broadcast-team <team_id>]"; return 0; }
      local channel_id="${1:-}"; need channel_id; shift
      local session_id="${EITS_SESSION_UUID:-}" body="" broadcast_team=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --session)         session_id="$2";    shift 2 ;;
          --body|-m)         body="$2";          shift 2 ;;
          --broadcast-team)  broadcast_team="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need session_id; need body
      _post "/channels/$channel_id/messages" \
        "$(json session_id "$session_id" body "$body" broadcast_to_team_id "$broadcast_team")"
      ;;
    messages)
      # eits channels messages <channel_id> [--limit N]
      local channel_id="${1:-}"; need channel_id; shift
      local limit="20"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --limit|-n) limit="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/channels/$channel_id/messages?limit=$limit" | jq .
      ;;
    join)
      # eits channels join <channel_id> [--session <uuid|id>] [--role <member|admin>]
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "usage: eits channels join <channel_id> [--session <uuid|id>] [--role member|admin]"; return 0; }
      local channel_id="${1:-}"; need channel_id; shift
      local session_id="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}" role=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --session) session_id="$2"; shift 2 ;;
          --role)    role="$2";       shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need session_id
      local payload
      payload="$(json session_id "$session_id")"
      [[ -n "$role" ]] && payload="$(echo "$payload" | jq --arg v "$role" '. + {role: $v}')"
      _post "/channels/$channel_id/members" "$payload"
      ;;
    leave)
      # eits channels leave <channel_id> [--session <uuid|id>]
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "usage: eits channels leave <channel_id> [--session <uuid|id>]"; return 0; }
      local channel_id="${1:-}"; need channel_id; shift
      local session_id="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --session) session_id="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need session_id
      _delete "/channels/$channel_id/members/$session_id"
      ;;
    *)
      cat <<USAGE
usage: eits channels <subcommand>

Subcommands:
  create   --name <name> [--project <id>] [--description <text>] [--type <public|private>]
           Create a new channel
  list     [--project <id>]                         List channels (optionally filter by project)
  send     <channel_id> --body <text> [--session <id>] [--broadcast-team <team_id>]
           Send a message; --broadcast-team fans out DMs to all team members after posting
  messages <channel_id> [--limit|-n <N>]            Get last N messages (default 20, max 200)
  join     <channel_id> [--session <uuid|id>] [--role <member|admin>]
           Join a channel (defaults to current session)
  leave    <channel_id> [--session <uuid|id>]
           Leave a channel (defaults to current session)

Examples:
  eits channels create --name "ops" --project 1 --description "Ops team channel"
  eits channels create --name "alerts" --type private
  eits channels list
  eits channels list --project 1
  eits channels send 1 --body "hello"
  eits channels send 1 --body "@all deploy done" --broadcast-team 296
  eits channels messages 1
  eits channels messages 1 -n 5
  eits channels join 1
  eits channels join 1 --role admin
  eits channels leave 1
USAGE
      ;;
  esac
}

# ── notifications ─────────────────────────────────────────────────────────────

cmd_notifications() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits notifications create --title <t> [--body <b>] [--category agent|job|system] [--resource-type <type>] [--resource-id <id>]"; return 0; }
  case "$sub" in
    create)
      # eits notifications create --title <t> [--body <b>] [--category <agent|job|system>] [--resource-type <type>] [--resource-id <id>]
      # --category maps to the API's category field (agent, job, system; default: system)
      # --resource-type and --resource-id link the notification to a resource
      local title="" body="" category="" resource_type="" resource_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --title)         title="$2";         shift 2 ;;
          --body)          body="$2";          shift 2 ;;
          --category)      category="$2";      shift 2 ;;
          --resource-type) resource_type="$2"; shift 2 ;;
          --resource-id)   resource_id="$2";   shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need title
      _post "/notifications" "$(json title "$title" body "$body" category "$category" resource_type "$resource_type" resource_id "$resource_id")"
      ;;
    *)
      echo "usage: eits notifications <create>"
      ;;
  esac
}

# ── prompts ───────────────────────────────────────────────────────────────────

cmd_prompts() {
  local sub="${1:-}"; shift || true
  [[ "${sub:-}" == "--help" || "${sub:-}" == "-h" ]] && { echo "usage: eits prompts <list|get|create>"; return 0; }
  case "$sub" in
    list)
      # eits prompts list [--query <q>] [--project <id>]
      local qs=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --query|-q)  qs="${qs}&query=$(printf '%s' "$2" | jq -Rr @uri)"; shift 2 ;;
          --project)   qs="${qs}&project_id=$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/prompts?${qs#&}" | jq .
      ;;
    get)
      # eits prompts get <id> [--project <id>] [--no-text]
      local id="${1:-}"; need id; shift
      local qs=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) qs="${qs}&project_id=$2"; shift 2 ;;
          --no-text) qs="${qs}&include_text=false"; shift ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/prompts/$id?${qs#&}" | jq .
      ;;
    create)
      # eits prompts create --name <n> --slug <s> --prompt-text <t> [--description <d>] [--project <id>] [--tags <json>] [--created-by <name>]
      local name="" slug="" prompt_text="" description="" project_id="" tags="" created_by=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)        name="$2";        shift 2 ;;
          --slug)        slug="$2";        shift 2 ;;
          --prompt-text) prompt_text="$2"; shift 2 ;;
          --description) description="$2"; shift 2 ;;
          --project)     project_id="$2";  shift 2 ;;
          --tags)        tags="$2";        shift 2 ;;
          --created-by)  created_by="$2";  shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need name; need slug; need prompt_text
      local body
      body="$(json name "$name" slug "$slug" prompt_text "$prompt_text" description "$description" project_id "$project_id" created_by "$created_by")"
      if [[ -n "$tags" ]]; then
        body=$(echo "$body" | jq --argjson t "$tags" '. + {tags: $t}')
      fi
      _post "/prompts" "$body"
      ;;
    *)
      echo "usage: eits prompts <list|get|create>"
      ;;
  esac
}

# ── teams ─────────────────────────────────────────────────────────────────────

cmd_teams() {
  local sub="${1:-}"; shift || true
  [[ "$sub" == "--help" || "$sub" == "-h" ]] && { echo "usage: eits teams <list|get|create|update|delete|members|join|status|update-member|done-self|leave|broadcast|my-teams>"; return 0; }
  case "$sub" in
    list)
      local project_id="" status=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) project_id="$2"; shift 2 ;;
          --status)  status="$2";     shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      local qs=""
      [[ -n "$project_id" ]] && qs="${qs}&project_id=${project_id}"
      [[ -n "$status"     ]] && qs="${qs}&status=${status}"
      _get "/teams${qs:+?${qs:1}}"
      ;;
    get)
      local id="${1:-}"; need id
      _get "/teams/$id"
      ;;
    create)
      local name="" description="" project_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)        name="$2";        shift 2 ;;
          --description) description="$2"; shift 2 ;;
          --project)     project_id="$2";  shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need name
      _post "/teams" "$(json name "$name" description "$description" project_id "$project_id")"
      ;;
    delete)
      local id="${1:-}"; need id
      _delete "/teams/$id"
      ;;
    update)
      # eits teams update <id> [--name <name>] [--description <desc>]
      local id="${1:-}"; need id; shift
      local name="" description=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)        name="${2:-}";        shift 2 ;;
          --description) description="${2:-}"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      [[ -n "$name" || -n "$description" ]] || die "at least --name or --description required"
      local payload
      payload=$(json name "$name" description "$description")
      _patch "/teams/$id" "$payload"
      ;;
    members)
      local id="${1:-}"; need id
      _get "/teams/$id/members"
      ;;
    join)
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && {
        cat <<'HELP'
usage: eits teams join <team_id> --name <alias> [--role member|admin] [--session <uuid|id>] [--agent <uuid>]

  --session  Session UUID or integer ID to join as. Defaults to:
             $EITS_SESSION_UUID (UUID) → $EITS_SESSION_ID (integer) → empty
  --agent    Agent UUID. Defaults to $EITS_AGENT_UUID.

NOTES:
  - Accepts both UUID and integer session/agent identifiers.
  - If EITS_SESSION_UUID is not set in a spawned agent, EITS_SESSION_ID is tried next.
HELP
        return 0; }
      local team_id="${1:-}"; need team_id; shift
      local name="" role="" session_id="" agent_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)    name="$2";       shift 2 ;;
          --role)    role="$2";       shift 2 ;;
          --session) session_id="$2"; shift 2 ;;
          --agent)   agent_id="$2";   shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need name
      session_id="${session_id:-${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}}"
      _post "/teams/$team_id/members" "$(json name "$name" role "$role" session_id "$session_id" agent_id "$agent_id")"
      ;;
    status)
      # eits teams status <id> [--summary|-s] [--wait]
      # member_status: team membership state (active, done, spawn_failed, idle) — authoritative for orchestrators
      # session_status: Claude process lifecycle (working, idle, waiting, completed, failed)
      [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && {
        cat <<'HELP'
usage: eits teams status <id> [--wait] [--json]

Default output: formatted summary with member status, session state, and current task.

Fields per member:
  member_status  — team membership state (active, done, spawn_failed, idle)
                   Use this to check if an agent is done with their work.
  session_status — Claude process lifecycle (working, idle, waiting, completed, failed)
                   Reflects the Claude Code process state, not task completion.
  session_uuid   — UUID for DM targeting; use with: eits dm --to <uuid> --message "..."
  session_id     — Numeric session ID (alternative DM target)
  task           — Current claimed task (title + ID) if any

Orchestrators should check member_status, not session_status.

--wait:         Block until all members have member_status done or spawn_failed.
                Polls every 5 seconds and prints a summary line each tick.
                Exits with 0 when all done, 1 if any spawn_failed.
--watch [<n>]:  Continuously refresh status every N seconds (default: 5).
                Clears the screen each tick. Press Ctrl+C to stop.
--json:         Output raw JSON instead of formatted text (useful for scripting).
HELP
        return 0; }
      local id="${1:-}"; need id; shift
      local summary=0 wait=0 json=0 watch=0 watch_interval=5
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --summary|-s) summary=1; shift ;;  # kept for compat; now same as default
          --wait)       wait=1;    shift ;;
          --watch)      watch=1;
                        # Accept optional interval: --watch 10
                        if [[ $# -gt 0 && "${2:-}" =~ ^[0-9]+$ ]]; then
                          watch_interval="$2"; shift 2
                        else
                          shift
                        fi ;;
          --json|--raw) json=1;    shift ;;  # raw JSON output for scripting
          *) die "unknown flag: $1" ;;
        esac
      done

      _teams_status_summary() {
        local resp
        resp=$(_curl "$BASE_URL/teams/$id") || return 1
        echo "$resp" | jq -r '
          . as $t |
          (.members // []) as $members |
          ($members | length) as $total |
          ($members | map(select(.session_status == "working")) | length) as $working |
          ($members | map(select(.session_status == "idle" or .session_status == "waiting")) | length) as $idle |
          ($members | map(select(.member_status == "done")) | length) as $done |
          ($members | map(select(.session_status == "failed")) | length) as $failed |
          ($members | map(select(.member_status == "spawn_failed")) | length) as $spawn_failed |
          "Team: \($t.name) (ID: \($t.id))",
          "Members: \($total) total — \($working) working, \($idle) idle, \($done) done\(if $failed > 0 then ", \($failed) session_failed" else "" end)\(if $spawn_failed > 0 then ", \($spawn_failed) spawn_failed" else "" end)",
          (if $total > 0 then
            "",
            "Member detail:",
            ($members[] |
              (.member_status // .status // "unknown") as $member_str |
              (if .session_status == "waiting" and .session_status_reason then
                "\(.session_status):\(.session_status_reason)"
              else
                (.session_status // "none")
              end) as $session_str |
              (if .claimed_task then " [task #\(.claimed_task.id): \(.claimed_task.title)]" else "" end) as $task_str |
              (.session_uuid // "—") as $uuid_str |
              (.session_id | tostring) as $sid_str |
              "  \(.name) (\(.role)) — member:\($member_str) session:\($session_str) uuid:\($uuid_str) id:\($sid_str)\($task_str)"
            )
          else empty end)
        '
      }

      if [[ $json -eq 1 ]]; then
        _curl "$BASE_URL/teams/$id" | jq .
      elif [[ $watch -eq 1 ]]; then
        # Continuous refresh mode — clears screen each tick until Ctrl+C
        while true; do
          clear
          printf '=== eits teams status %s  [watch: every %ds, Ctrl+C to stop] ===\n\n' "$id" "$watch_interval"
          _teams_status_summary 2>&1 || printf '[error fetching team status]\n'
          sleep "$watch_interval"
        done
      elif [[ $wait -eq 1 ]]; then
        local spawn_failed_count=0 _wait_delay=2
        while true; do
          local resp _wait_body _wait_status
          _wait_body=$(curl -sk --write-out '\n%{http_code}' ${AUTH_ARGS[@]+"${AUTH_ARGS[@]}"} ${ROLE_ARGS[@]+"${ROLE_ARGS[@]}"} ${SESSION_ARGS[@]+"${SESSION_ARGS[@]}"} "$BASE_URL/teams/$id")
          _wait_status="${_wait_body##*$'\n'}"
          _wait_body="${_wait_body%$'\n'*}"
          # Only retry on rate-limit (429) or server errors (5xx) — all other 4xx are permanent.
          if [[ "$_wait_status" == "429" || "$_wait_status" -ge 500 ]]; then
            local _sleep_time=$(_backoff "$_wait_delay")
            printf 'teams status --wait: transient error (HTTP %s), retrying in %ds\n' "$_wait_status" "$_sleep_time" >&2
            sleep "$_sleep_time"
            _wait_delay=$((_wait_delay * 2))
            [[ $_wait_delay -gt 30 ]] && _wait_delay=30
            continue
          fi
          if [[ "$_wait_status" -ge 400 ]]; then
            printf 'teams status --wait: permanent error (HTTP %s) — %s\n' "$_wait_status" "$_wait_body" >&2
            return 1
          fi
          resp="$_wait_body"
          local pending
          pending=$(echo "$resp" | jq '[.members // [] | .[] | select(.member_status != "done" and .member_status != "spawn_failed")] | length')
          spawn_failed_count=$(echo "$resp" | jq '[.members // [] | .[] | select(.member_status == "spawn_failed")] | length')
          local done_count total
          done_count=$(echo "$resp" | jq '[.members // [] | .[] | select(.member_status == "done")] | length')
          total=$(echo "$resp" | jq '.members // [] | length')
          printf '[%s] waiting: %d/%d done, %d pending\n' "$(date -u +%H:%M:%S)" "$done_count" "$total" "$pending" >&2
          if [[ "$pending" -eq 0 ]]; then
            echo "$resp" | jq -r '
              . as $t |
              (.members // []) as $members |
              ($members | length) as $total |
              ($members | map(select(.member_status == "done")) | length) as $done |
              ($members | map(select(.member_status == "spawn_failed")) | length) as $spawn_failed |
              "Team: \($t.name) (ID: \($t.id)) — all members settled.",
              "Done: \($done)/\($total)\(if $spawn_failed > 0 then ", spawn_failed: \($spawn_failed)" else "" end)",
              "",
              "Final member status:",
              ($members[] |
                (.member_status // .status // "unknown") as $member_str |
                (.session_uuid // "—") as $uuid_str |
                (.session_id | tostring) as $sid_str |
                (if .claimed_task then " [task #\(.claimed_task.id): \(.claimed_task.title)]" else "" end) as $task_str |
                "  \(.name) (\(.role)) — \($member_str) uuid:\($uuid_str) id:\($sid_str)\($task_str)"
              )
            '
            [[ "$spawn_failed_count" -gt 0 ]] && return 1 || return 0
          fi
          sleep 5
        done
      else
        _teams_status_summary
      fi
      ;;
    update-member)
      local team_id="${1:-}"; need team_id; shift
      local member_id="${1:-}"; need member_id; shift
      local status=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --status) status="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need status
      _patch "/teams/$team_id/members/$member_id" "$(json status "$status")"
      ;;
    done-self)
      # eits teams done-self <team_id>
      # Finds the current session's member in the team and marks them done.
      local team_id="${1:-}"; need team_id
      local session_uuid="${EITS_SESSION_UUID:-}"
      [[ -n "$session_uuid" ]] || die "EITS_SESSION_UUID is required (or set it explicitly)"

      local members_resp
      members_resp=$(_curl "$BASE_URL/teams/$team_id/members") \
        || die "failed to fetch members for team $team_id"

      local member_id
      member_id=$(echo "$members_resp" | jq -r --arg uuid "$session_uuid" \
        '.members[] | select(.session_uuid == $uuid) | .id' 2>/dev/null)

      [[ -n "$member_id" ]] || die "current session not found in team $team_id members"

      _patch "/teams/$team_id/members/$member_id" '{"status":"done"}'
      ;;
    leave)
      local team_id="${1:-}"; need team_id; shift
      local member_id="${1:-}"; need member_id
      _delete "/teams/$team_id/members/$member_id"
      ;;
    broadcast)
      # eits teams broadcast <team_id> --body <text> [--from <session>]
      # POSTs to POST /api/v1/teams/:team_id/broadcast (atomic server-side fanout)
      local team_id="${1:-}"; need team_id; shift
      local from="${EITS_SESSION_UUID:-${EITS_SESSION_ID:-}}" body=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --from|-f)               from="$2";  shift 2 ;;
          --body|-b|-m|--message)  body="$2";  shift 2 ;;
          # Deprecated flags accepted for backward compat; server handles fanout now
          --include-self|--response-required)
            if [[ "${2:-}" != --* && -n "${2:-}" ]]; then shift 2; else shift; fi ;;

          *) die "unknown flag: $1" ;;
        esac
      done
      need from; need body
      _post "/teams/$team_id/broadcast" "$(json from_session_id "$from" body "$body")"
      ;;
    my-teams)
      # List teams where the current agent is a member (by EITS_AGENT_UUID).
      # Uses ?member_agent_uuid= server filter — single request, no N+1.
      local agent_uuid="${EITS_AGENT_UUID:-}"; need agent_uuid
      _curl "$BASE_URL/teams?member_agent_uuid=$(printf '%s' "$agent_uuid" | jq -Rr @uri)" | jq .
      ;;
    *)
      echo "usage: eits teams <list|get|create|update|delete|members|join|status|update-member|done-self|leave|broadcast|my-teams>"
      ;;
  esac
}

# ── worktree ──────────────────────────────────────────────────────────────────
# NOTE: Scoped to EITS Elixir projects (.claude/worktrees/ layout, mix compile).

cmd_worktree() {
  local subcmd="${1:-}"; shift || true
  [[ "${subcmd:-}" == "--help" || "${subcmd:-}" == "-h" ]] && { echo "usage: eits worktree <create|remove>"; return 0; }
  case "$subcmd" in
    create)
      local branch="${1:-}"; need branch; shift || true
      local project_path="${EITS_PROJECT_PATH:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project-path) project_path="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done

      local wt_path="$project_path/.claude/worktrees/$branch"

      if [[ -d "$wt_path" ]] && [[ -e "$wt_path/.git" ]]; then
        echo "Worktree already exists at $wt_path — reusing"
      else
        local start_point="origin/main"
        echo "Fetching origin/main..."
        if ! git -C "$project_path" fetch origin main --quiet 2>&1; then
          echo "warning: fetch failed, branching from local HEAD"
          start_point=""
        fi
        echo "Creating worktree: $wt_path (branch: $branch)"
        git -C "$project_path" worktree add "$wt_path" -b "$branch" $start_point 2>&1 \
          || die "git worktree add failed. If branch exists: git branch -D $branch"
      fi

      if [[ ! -e "$wt_path/deps" ]]; then
        local deps_source="$project_path/deps"
        [[ -d "$deps_source" ]] || die "deps not found at $deps_source — run mix deps.get first"
        ln -s ../../../deps "$wt_path/deps" \
          || echo "warning: could not symlink deps (may already exist)"
      fi

      echo "Verifying compile..."
      local clean_path
      clean_path=$(echo "$PATH" | tr ':' '\n' | grep -Ev '_build/prod/rel|/erts-' | tr '\n' ':' | sed 's/:$//')

      local output exit_code
      output=$(cd "$wt_path" && PATH="$clean_path" mix compile 2>&1) && exit_code=0 || exit_code=$?

      if [[ $exit_code -ne 0 ]]; then
        echo "Compile failed:"
        echo "$output" | tail -20
        die "Worktree setup failed — fix compile errors before proceeding"
      fi

      echo ""
      echo "Worktree ready:"
      echo "  Path:   $wt_path"
      echo "  Branch: $branch"
      echo ""
      echo "Usage:"
      echo "  cd $wt_path"
      echo "  export PATH=\$(echo \"\$PATH\" | tr ':' '\n' | grep -Ev '_build/prod/rel|/erts-' | tr '\n' ':' | sed 's/:\$//')"
      ;;

    remove)
      local branch="${1:-}"; need branch; shift || true
      local project_path="${EITS_PROJECT_PATH:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project-path) project_path="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done

      local wt_path="$project_path/.claude/worktrees/$branch"

      if [[ -L "$wt_path/deps" ]]; then
        unlink "$wt_path/deps" 2>/dev/null || true
      fi

      if [[ -d "$wt_path" ]]; then
        git -C "$project_path" worktree remove "$wt_path" --force 2>/dev/null || true
      fi

      git -C "$project_path" branch -D "$branch" 2>/dev/null || true

      echo "Removed: $branch"
      ;;

    *)
      echo "usage: eits worktree <create|remove>"
      echo ""
      echo "NOTE: scoped to EITS Elixir projects (.claude/worktrees/ layout, mix compile verification)"
      ;;
  esac
}

# ── queue (pending annotations) ───────────────────────────────────────────────
#
# `eits tasks annotate` queues to ~/.eits/pending-annotations.log on persistent
# 429s. `eits queue status` shows what's pending; `eits queue flush` replays it.

_pending_log() { printf '%s/.eits/pending-annotations.log' "$HOME"; }

cmd_queue() {
  local subcmd="${1:-}"; shift || true
  [[ "${subcmd:-}" == "--help" || "${subcmd:-}" == "-h" ]] && {
    cat <<EOF
usage: eits queue <status|flush>

  status   Print pending annotation count + per-task summary
  flush    Replay pending annotations; drop successes, keep failures.
           Exits non-zero if any entries remain or any POST fails.

Queue file: ~/.eits/pending-annotations.log (JSONL)
EOF
    return 0
  }
  case "$subcmd" in
    status)
      local log; log="$(_pending_log)"
      if [[ ! -s "$log" ]]; then
        echo "queue empty"
        return 0
      fi
      local total; total=$(wc -l < "$log" | tr -d ' ')
      echo "pending annotations: $total"
      echo "log: $log"
      echo ""
      echo "by task_id:"
      # task_id is stored as a JSON string; -r drops quotes
      jq -r '.task_id' "$log" | sort | uniq -c | sort -rn | awk '{printf "  %5s  task %s\n", $1, $2}'
      ;;
    flush)
      local log; log="$(_pending_log)"
      if [[ ! -s "$log" ]]; then
        echo "queue empty"
        return 0
      fi
      local tmp; tmp="$(mktemp)"
      local ok=0 fail=0 line task_id body title status body_out
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        task_id=$(printf '%s' "$line" | jq -r '.task_id // empty')
        body=$(printf    '%s' "$line" | jq -r '.body    // empty')
        title=$(printf   '%s' "$line" | jq -r '.title   // empty')
        if [[ -z "$task_id" || -z "$body" ]]; then
          echo "skip: malformed entry" >&2
          printf '%s\n' "$line" >> "$tmp"
          fail=$((fail + 1))
          continue
        fi
        local payload; payload=$(json body "$body" title "$title")
        body_out=$(curl -sk --write-out '\n%{http_code}' -X POST \
          -H "Content-Type: application/json" \
          ${AUTH_ARGS[@]+"${AUTH_ARGS[@]}"} ${ROLE_ARGS[@]+"${ROLE_ARGS[@]}"} ${SESSION_ARGS[@]+"${SESSION_ARGS[@]}"} \
          -d "$payload" \
          "$BASE_URL/tasks/$task_id/annotations" 2>/dev/null) || body_out=$'\n000'
        status="${body_out##*$'\n'}"
        body_out="${body_out%$'\n'*}"
        if [[ "$status" =~ ^[0-9]+$ ]] && [[ "$status" -lt 400 ]] && [[ "$status" != "000" ]]; then
          ok=$((ok + 1))
          echo "ok:   task $task_id"
        else
          fail=$((fail + 1))
          echo "fail: task $task_id (HTTP $status)" >&2
          printf '%s\n' "$line" >> "$tmp"
        fi
      done < "$log"

      if [[ -s "$tmp" ]]; then
        mv "$tmp" "$log"
      else
        rm -f "$tmp" "$log"
      fi

      echo ""
      echo "flushed: $ok ok, $fail remaining"
      [[ $fail -eq 0 ]]
      ;;
    ""|*)
      echo "usage: eits queue <status|flush>"
      [[ -n "$subcmd" ]] && return 1 || return 0
      ;;
  esac
}

# ── search ────────────────────────────────────────────────────────────────────

cmd_search() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat <<EOF
usage: eits search <query> [--type sessions|tasks|notes] [--limit <n>] [--project <id>] [--json]

Full-text search across sessions, tasks, and notes in one shot.

Options:
  --type <csv>    Entity types to search, comma-separated (default: sessions,tasks,notes)
  --limit <n>     Max results per entity type (default: 5)
  --project <id>  Scope to a project
  --json          Emit combined JSON: {"sessions":[...],"tasks":[...],"notes":[...]}

Examples:
  eits search "auth"
  eits search "migration" --type tasks,notes --limit 10
  eits search "deploy" --json
EOF
    return 0
  fi

  local query="" types="sessions,tasks,notes" limit=5 project="" json_mode=0

  # first non-flag arg is the query
  if [[ -n "${1:-}" && "${1:0:1}" != "-" ]]; then
    query="$1"; shift
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)
        [[ $# -lt 2 || "${2:0:1}" == "-" ]] && die "--type requires a value (sessions|tasks|notes)"
        types="$2"; shift 2 ;;
      --limit|-l)
        [[ $# -lt 2 || "${2:0:1}" == "-" ]] && die "--limit requires a numeric value"
        [[ "$2" =~ ^[0-9]+$ ]] || die "--limit must be a positive integer, got: $2"
        limit="$2"; shift 2 ;;
      --project|-p)
        [[ $# -lt 2 || "${2:0:1}" == "-" ]] && die "--project requires a value"
        [[ "$2" =~ ^[0-9]+$ ]] || die "--project must be a numeric ID, got: $2"
        project="$2"; shift 2 ;;
      --json)        json_mode=1;  shift ;;
      *) die "unknown option: $1" ;;
    esac
  done

  [[ -z "$query" ]] && die "usage: eits search <query>"

  # validate --type tokens strictly — exact token match, no substring
  local do_sessions=0 do_tasks=0 do_notes=0
  local _t; IFS=',' read -ra _type_tokens <<< "$types"
  for _t in "${_type_tokens[@]}"; do
    case "$_t" in
      sessions) do_sessions=1 ;;
      tasks)    do_tasks=1 ;;
      notes)    do_notes=1 ;;
      *) die "unknown type: '$_t' (valid: sessions, tasks, notes)" ;;
    esac
  done

  local q_enc; q_enc=$(printf '%s' "$query" | jq -Rr @uri)
  local proj_qs=""; [[ -n "$project" ]] && proj_qs="&project_id=${project}"

  local tmp_dir; tmp_dir=$(mktemp -d)
  # trap ensures cleanup on early exit, error, or signal
  trap '/bin/rm -rf "$tmp_dir" 2>/dev/null || true' EXIT INT TERM

  local f_sessions="${tmp_dir}/sessions.json"
  local f_tasks="${tmp_dir}/tasks.json"
  local f_notes="${tmp_dir}/notes.json"

  # write empty defaults so each file always exists
  echo '{"sessions":[]}' > "$f_sessions"
  echo '{"tasks":[]}'    > "$f_tasks"
  echo '{"notes":[]}'    > "$f_notes"

  # fan out in parallel — only requested types
  [[ $do_sessions -eq 1 ]] && \
    ( _curl "${BASE_URL}/sessions?q=${q_enc}&limit=${limit}${proj_qs}" > "$f_sessions" 2>/dev/null ) &
  [[ $do_tasks -eq 1 ]] && \
    ( _curl "${BASE_URL}/tasks?q=${q_enc}&limit=${limit}${proj_qs}" > "$f_tasks" 2>/dev/null ) &
  [[ $do_notes -eq 1 ]] && \
    ( _curl "${BASE_URL}/notes?q=${q_enc}&limit=${limit}${proj_qs}" > "$f_notes" 2>/dev/null ) &
  wait

  if [[ $json_mode -eq 1 ]]; then
    jq -n \
      --slurpfile s "$f_sessions" \
      --slurpfile t "$f_tasks" \
      --slurpfile n "$f_notes" \
      '{
        sessions: ($s[0].sessions // []),
        tasks:    ($t[0].tasks    // []),
        notes:    ($n[0].notes    // [])
      }'
  else
    local s_count t_count n_count
    s_count=$(jq '[.sessions[]?] | length' "$f_sessions" 2>/dev/null); s_count=${s_count:-0}
    t_count=$(jq '[.tasks[]?]    | length' "$f_tasks"    2>/dev/null); t_count=${t_count:-0}
    n_count=$(jq '[.notes[]?]    | length' "$f_notes"    2>/dev/null); n_count=${n_count:-0}

    [[ $do_sessions -eq 1 && "$s_count" -gt 0 ]] && {
      printf '\n── Sessions (%s) ──────────────────────────────────────────────\n' "$s_count"
      _tbl_sessions "$(cat "$f_sessions")"
    }
    [[ $do_tasks -eq 1 && "$t_count" -gt 0 ]] && {
      printf '\n── Tasks (%s) ─────────────────────────────────────────────────\n' "$t_count"
      _tbl_tasks "$(cat "$f_tasks")"
    }
    [[ $do_notes -eq 1 && "$n_count" -gt 0 ]] && {
      printf '\n── Notes (%s) ─────────────────────────────────────────────────\n' "$n_count"
      _tbl_notes "$(cat "$f_notes")"
    }

    local total=$(( s_count + t_count + n_count ))
    if [[ $total -eq 0 ]]; then
      printf '\nNo results for "%s"\n' "$query"
    else
      printf '\n%s result(s) for "%s"\n' "$total" "$query"
    fi
  fi

  trap - EXIT INT TERM
  /bin/rm -rf "$tmp_dir" 2>/dev/null || true
}

# ── me / whoami ───────────────────────────────────────────────────────────────

cmd_me() {
  local uuid="${EITS_SESSION_UUID:-}"
  local ok="✓" fail="✗"

  # ── identity ──────────────────────────────────────────────────────────────
  printf '\n── Identity ─────────────────────────────────────────────────\n'
  printf '  Session UUID : %s\n' "${EITS_SESSION_UUID:-(not set)}"
  printf '  Session ID   : %s\n' "${EITS_SESSION_ID:-(not set)}"
  printf '  Agent UUID   : %s\n' "${EITS_AGENT_UUID:-(not set)}"
  printf '  Project ID   : %s\n' "${EITS_PROJECT_ID:-(not set)}"
  printf '  API URL      : %s\n' "${BASE_URL}"

  # ── tracking status ───────────────────────────────────────────────────────
  printf '\n── Tracking Status ──────────────────────────────────────────\n'
  [[ -n "${EITS_SESSION_UUID:-}" ]]  && printf '  %s Session UUID set\n' "$ok" || printf '  %s Session UUID NOT set — work may be untracked\n' "$fail"
  [[ -n "${EITS_AGENT_UUID:-}" ]]    && printf '  %s Agent UUID set\n'   "$ok" || printf '  %s Agent UUID NOT set — commits/sessions may not link\n' "$fail"
  [[ -n "${EITS_PROJECT_ID:-}" ]]    && printf '  %s Project ID set\n'   "$ok" || printf '  %s Project ID NOT set — tasks will be unscoped\n' "$fail"

  # ── server reachability ───────────────────────────────────────────────────
  local _ping
  _ping=$(curl -sk --max-time 3 "$BASE_URL/sessions?limit=0" -o /dev/null -w '%{http_code}' \
    ${AUTH_ARGS[@]+"${AUTH_ARGS[@]}"} ${SESSION_ARGS[@]+"${SESSION_ARGS[@]}"} 2>/dev/null)
  if [[ "$_ping" == "200" || "$_ping" == "204" ]]; then
    printf '  %s Server reachable (%s)\n' "$ok" "$BASE_URL"
  else
    printf '  %s Server NOT reachable at %s (HTTP %s)\n' "$fail" "$BASE_URL" "${_ping:-(no response)}"
    printf '    Fix: ensure mix phx.server is running, or set EITS_URL correctly\n'
  fi

  # ── current task ──────────────────────────────────────────────────────────
  if [[ -n "$uuid" ]]; then
    printf '\n── Current Task ─────────────────────────────────────────────\n'
    local _tasks
    _tasks=$(_curl "$BASE_URL/tasks?session_id=$uuid&state_id=2&limit=3" 2>/dev/null) || true
    local _count; _count=$(echo "$_tasks" | jq '[.tasks[]?] | length' 2>/dev/null || echo 0)
    if [[ "$_count" -gt 0 ]]; then
      echo "$_tasks" | jq -r '.tasks[]? | "  #\(.id)  \(.state // "In Progress")  \(.title // "(untitled)")"'
    else
      printf '  (no In Progress tasks for this session)\n'
      printf '  Start one: eits tasks begin --title "Task name"\n'
    fi
  fi

  # ── workflow reminder ─────────────────────────────────────────────────────
  printf '\n── Canonical Workflow ───────────────────────────────────────\n'
  printf '  1. eits tasks begin --title "Task name"      # create + claim\n'
  printf '  2. eits tasks annotate <id> --body "..."     # add notes\n'
  printf '  3. eits tasks complete <id> --message "..."  # annotate + done\n'
  printf '     eits commits create --hash <sha>          # log commits\n'
  printf '\n'
}

# ── help ──────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
eits — Eye in the Sky CLI
Base URL: ${BASE_URL}  (override: EITS_URL=<url>)

Commands:
  sessions      list|get|create|update|end|context   (list --search <q> for full-text)
  tasks         list|get|create|update|bulk-update|done|begin|complete|annotate|start|claim|delete|link-session|unlink-session|search
                list --mine, update --title, begin --quiet, search <query> [--project <id>] [--state <id>] [--limit <n>]
  notes         list|get|create|update|add|search   (search <query> for full-text)
  projects      list|get|create
  agents        list|get|spawn
  commits       list|create
  jobs          list|get|create|update|run|delete
  dm            list [--session <uuid|id>] [--limit <n>]
  dm            [--from <session_id|uuid>] --to <session_id|uuid> --message <text> [--response-required]
  channels      list|send|messages
  notifications create
  prompts       list|get
  teams         list|get|create|update|delete|members|join|status|update-member|leave|broadcast|my-teams
  timer         show|set|cancel   (default session: self / $EITS_SESSION_UUID)
  worktree      create|remove   (EITS Elixir projects only)
  queue         status|flush    (drain ~/.eits/pending-annotations.log)
  search        <query> [--type sessions|tasks|notes] [--limit <n>] [--project <id>] [--json]
  me            Print current session/agent/project context and verify server-side

Env vars (injected by EITS hooks):
  EITS_SESSION_UUID  current session UUID (default --session / --from / --mine)
  EITS_SESSION_ID    current session integer ID (fallback when UUID unavailable, e.g. Codex spawns)
  EITS_AGENT_UUID    current agent UUID   (default --agent)
  EITS_PROJECT_ID    current project ID   (default --project / tasks begin / agents spawn)
  EITS_URL           API base URL         (default: http://localhost:5001/api/v1)

Fallback order for session identity:
  UUID preferred; integer ID used when UUID is empty (tasks, teams join, --mine, dm --from)
  Run: eits me   — to verify which env vars are set in the current shell

Requires: curl, jq
EOF
}

# ── dispatch ──────────────────────────────────────────────────────────────────

cmd="${1:-}"; shift || true
case "$cmd" in
  sessions)      cmd_sessions      "$@" ;;
  tasks)         cmd_tasks         "$@" ;;
  notes)         cmd_notes         "$@" ;;
  projects)      cmd_projects      "$@" ;;
  agents)        cmd_agents        "$@" ;;
  commits)       cmd_commits       "$@" ;;
  jobs)          cmd_jobs          "$@" ;;
  dm)            cmd_dm            "$@" ;;
  channels)      cmd_channels      "$@" ;;
  notifications) cmd_notifications "$@" ;;
  prompts)       cmd_prompts       "$@" ;;
  teams)         cmd_teams         "$@" ;;
  timer)         cmd_timer         "$@" ;;
  worktree)      cmd_worktree      "$@" ;;
  queue)         cmd_queue         "$@" ;;
  search)        cmd_search        "$@" ;;
  me|whoami)     cmd_me ;;
  help|--help|-h) usage ;;
  "") usage; exit 0 ;;
  *) die "unknown command: $cmd" ;;
esac
