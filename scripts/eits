}

# ── dm ────────────────────────────────────────────────────────────────────────

cmd_dm() {
  # eits dm [--from <sender_id>] --to <target_session_uuid|session_int_id> --message <text> [--response-required]
  # --from defaults to $EITS_AGENT_UUID when omitted
  local sender_id="${EITS_AGENT_UUID:-}" target="" message="" response_required="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from)              sender_id="$2";         shift 2 ;;
      --to)                target="$2";            shift 2 ;;
      --message|-m)        message="$2";           shift 2 ;;
      --response-required) response_required="true"; shift ;;
      *) die "unknown flag: $1" ;;
    esac
  done
  need sender_id; need target; need message

  # Resolve integer session ID to UUID — /dm requires UUIDs
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    local resolved
    resolved=$(_curl "$BASE_URL/sessions/$target" | jq -r '.uuid // empty' 2>/dev/null || true)
    [[ -n "$resolved" ]] || die "could not resolve session integer ID $target to UUID"
    target="$resolved"
  fi

  local payload
  payload=$(jq -n --arg s "$sender_id" --arg t "$target" --arg m "$message" --argjson r "$response_required" \
    '{sender_id: $s, target_session_id: $t, message: $m, response_required: $r}')
  _post "/dm" "$payload"
}

# ── channels ──────────────────────────────────────────────────────────────────

cmd_channels() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    list)
      local project_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project) project_id="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      if [[ -n "$project_id" ]]; then
        _curl "$BASE_URL/channels?project_id=$project_id" | jq .
      else
        _get "/channels"
      fi
      ;;
    send)
      # eits channels send <channel_id> --session <uuid> --body <text>
      local channel_id="${1:-}"; need channel_id; shift
      local session_id="" body=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --session) session_id="$2"; shift 2 ;;
          --body|-m) body="$2";       shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      need session_id; need body
      _post "/channels/$channel_id/messages" "$(json session_id "$session_id" body "$body")"
      ;;
    messages)
      # eits channels messages <channel_id> [--limit N]
      local channel_id="${1:-}"; need channel_id; shift
      local limit="20"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --limit|-n) limit="$2"; shift 2 ;;
          *) die "unknown flag: $1" ;;
        esac
      done
      _curl "$BASE_URL/channels/$channel_id/messages?limit=$limit" | jq .
      ;;
    *)
      cat <<USAGE
usage: eits channels <subcommand>

Subcommands:
  list     [--project <id>]                         List channels (optionally filter by project)
  send     <channel_id> --session <id> --body <text> Send a message to a channel
  messages <channel_id> [--limit|-n <N>]            Get last N messages (default 20, max 200)

Examples:
  eits channels list
  eits channels list --project 1
  eits channels send 1 --session 1179 --body "hello"
  eits channels messages 1
  eits channels messages 1 -n 5
USAGE
      ;;
  esac
}

