#!/usr/bin/env bash
# i-chat - Channel messaging
# Usage:
#   i-chat send CHANNEL_ID MESSAGE [--session_id UUID]
#   i-chat list [--project_id N]

set -euo pipefail

BASE=${EITS_API_URL:-https://localhost:4000/api/v1}
SESSION_ID=${EITS_SESSION_ID:-}
PROJECT_ID=${EITS_PROJECT_ID:-}

_curl() { curl -sk "$@"; }
_ok() { local r="$1"; echo "$r" | jq .; if echo "$r" | jq -e '.error' &>/dev/null; then exit 1; fi; }

cmd="${1:-list}"
shift || true

case "$cmd" in
  send)
    channel_id="${1:?channel id required}"; shift
    message="${1:?message required}"; shift
    session_id="$SESSION_ID"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --session_id) session_id="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    body=$(jq -n --arg sid "$session_id" --arg msg "$message" '{session_id: $sid, body: $msg}')
    _ok "$(_curl -X POST "$BASE/channels/$channel_id/messages" -H 'Content-Type: application/json' -d "$body")"
    ;;

  list)
    params=""
    while [[ $# -gt 0 ]]; do
      case "$1" in --project_id) params="?project_id=$2"; shift 2 ;; *) shift ;; esac
    done
    [[ -z "$params" && -n "$PROJECT_ID" ]] && params="?project_id=$PROJECT_ID"
    _ok "$(_curl "$BASE/channels$params")"
    ;;

  *)
    echo "Usage: i-chat <send|list> [args...]" >&2
    exit 1
    ;;
esac
