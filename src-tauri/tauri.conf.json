{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Eye in the Sky",
  "version": "0.1.0",
  "identifier": "com.eits.EyeInTheSky",
  "build": {
    "beforeBuildCommand": "MIX_ENV=prod mix do compile + assets.deploy + release --overwrite --path src-tauri/target/rel",
    "beforeDevCommand": "mkdir -p src-tauri/target/rel"
  },
  "app": {
    "macOSPrivateApi": false,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "target/rel": "rel"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["eits"]
      }
    }
  }
}
